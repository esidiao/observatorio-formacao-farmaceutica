{% extends "base.html.j2" %}

{% block title %}{{ sigla }} — Observatório Nacional da Formação Farmacêutica{% endblock %}
{% block meta_description %}Farmácia em {{ nome_uf }}: {{ d.vagas_total_real or d.vagas_total or 0 }} vagas, {{ d.n_ies or 0 }} IES, {{ d.municipios_oferta or 0 }} municípios com oferta e {{ d.municipios_deserto or 0 }} desertos. Indicadores ICT, IAF, IDD e cobertura assistencial (Censo {{ meta.versao_censo }}/ENADE 2023).{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "Formação farmacêutica em {{ nome_uf }} ({{ sigla }}) — indicadores",
  "description": "Indicadores de Farmácia em {{ nome_uf }}: vagas (presencial e EaD), IES, municípios com oferta e desertos, concentração territorial (ICT), qualidade (ENADE/IDD/CPC) e cobertura assistencial.",
  "url": "{{ meta.site_url }}/uf/{{ sigla }}.html",
  "inLanguage": "pt-BR",
  "isAccessibleForFree": true,
  "license": "{{ meta.site_url }}/aviso-legal.html",
  "temporalCoverage": "{{ meta.versao_censo }}",
  "spatialCoverage": { "@type": "Place", "name": "{{ nome_uf }}, Brasil" },
  "keywords": ["Farmácia", "{{ nome_uf }}", "educação superior", "INEP", "ENADE"],
  "creator": { "@id": "{{ meta.site_url }}/#autor" },
  "isPartOf": { "@id": "{{ meta.site_url }}/#website" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Início", "item": "{{ meta.site_url }}/" },
    { "@type": "ListItem", "position": 2, "name": "{{ nome_uf }} ({{ sigla }})", "item": "{{ meta.site_url }}/uf/{{ sigla }}.html" }
  ]
}
</script>
{% endblock %}

{% block breadcrumb %}
<a href="{{ depth }}index.html">Início</a>
<span class="sep">›</span>
<span class="active">{{ sigla }}</span>
{% endblock %}

{% block content %}

{# Macro: seta de variação 2023→2024 a partir do historico.json #}
{% macro delta(ind, casas=3) %}
  {%- set h = hist.get(ind) -%}
  {%- if h and h.delta is not none -%}
    {%- set t = h.tendencia -%}
    {%- set cor = 'var(--swot-strength)' if t == 'melhora' else ('var(--swot-threat)' if t == 'piora' else 'var(--text-muted)') -%}
    {%- set seta = '▲' if h.delta > 0 else ('▼' if h.delta < 0 else '▬') -%}
    <div class="kpi-delta" style="font-size:0.72rem;font-weight:600;color:{{ cor }};margin-top:2px"
         title="2023: {{ h['2023'] }} → 2024: {{ h['2024'] }} ({{ t }})">
      {{ seta }} {{ "%+.*f"|format(casas, h.delta) }} vs 2023
    </div>
  {%- endif -%}
{% endmacro %}

<!-- Cabeçalho da UF -->
<div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;flex-wrap:wrap">
  <h2 style="font-size:1.5rem;color:var(--navy)">{{ nome_uf }}</h2>
  <span class="uf-tag" style="font-size:1rem;padding:4px 12px">{{ sigla }}</span>
  <span style="flex:1"></span>
  <button class="btn outline" onclick="exportarJSON(DADOS_UF, 'observatorio_{{ sigla }}.json')" style="font-size:0.8rem;padding:6px 12px">↓ JSON</button>
  <button class="btn outline" style="font-size:0.8rem;padding:6px 12px" onclick="exportarUFCSV()">↓ CSV</button>
</div>

<!-- KPIs -->
<h2 class="section-title">Indicadores principais</h2>
<div class="kpi-grid">

  <div class="kpi-card {% if d.ICT is not none %}{% if d.ICT < 0.5 %}bom{% elif d.ICT >= 0.75 %}critico{% endif %}{% else %}nodata{% endif %}">
    <div class="kpi-valor">{% if d.ICT is not none %}{{ "%.3f"|format(d.ICT) }}{% else %}—{% endif %}</div>
    <div class="kpi-label">ICT ↓</div>
    {{ delta('ICT', 3) }}
    <div class="kpi-fonte" title="Índice de Concentração Territorial. Fonte: Censo INEP {{ meta.versao_censo }}.">Censo {{ meta.versao_censo }}</div>
  </div>

  <div class="kpi-card {% if d.IAF is not none %}{% if d.IAF >= 40 %}bom{% elif d.IAF < 25 %}critico{% endif %}{% else %}nodata{% endif %}">
    <div class="kpi-valor">{% if d.IAF is not none %}{{ "%.1f"|format(d.IAF) }}{% else %}—{% endif %}</div>
    <div class="kpi-label">IAF ↑ (0–100)</div>
    {{ delta('IAF', 1) }}
    <div class="kpi-fonte" title="Índice de Adequação Formativa. Fonte: ENADE {{ meta.versao_censo }}.">ENADE {{ meta.versao_censo }}</div>
  </div>

  <div class="kpi-card">
    <div class="kpi-valor">{% if d.ICON is not none %}{{ "%.1f"|format(d.ICON) }}{% else %}—{% endif %}</div>
    <div class="kpi-label">ICON ↑</div>
    {{ delta('ICON', 3) }}
    <div class="kpi-fonte" title="Índice de Cobertura Assistencial = municípios com Farmácia Popular / municípios com oferta. Fonte: Min. Saúde.">Farmácia Popular</div>
  </div>

  <div class="kpi-card">
    <div class="kpi-valor">{% if d.ICON_adj is not none %}{{ "%.3f"|format(d.ICON_adj) }}{% else %}—{% endif %}</div>
    <div class="kpi-label">ICON-deserto ↑</div>
    <div class="kpi-fonte" title="Fração estimada de desertos farmacêuticos com Farmácia Popular (limite inferior). Mede potencial de ancoragem de práticas/estágios onde NÃO há curso. Difere do ICON, que mede FP onde já há oferta.">FP em desertos</div>
  </div>

  <div class="kpi-card">
    <div class="kpi-valor">{% if d.E is not none %}{{ "%.3f"|format(d.E) }}{% else %}—{% endif %}</div>
    <div class="kpi-label">E (Equidade) ↑</div>
    {{ delta('E', 3) }}
    <div class="kpi-fonte" title="E = 1 − ICT. Mede distribuição territorial.">Calculado</div>
  </div>

  <div class="kpi-card">
    <div class="kpi-valor">{{ "{:,}".format(d.vagas_total or 0).replace(',','.') }}</div>
    <div class="kpi-label">Vagas (operante)</div>
    <div class="kpi-fonte" title="Vagas anuais em funcionamento. Fonte: Censo INEP {{ meta.versao_censo }}.">Censo {{ meta.versao_censo }}</div>
  </div>

  <div class="kpi-card">
    <div class="kpi-valor">{{ d.n_ies or '—' }}</div>
    <div class="kpi-label">IES com Farmácia</div>
    <div class="kpi-fonte" title="Número de Instituições de Ensino Superior. Fonte: Censo INEP {{ meta.versao_censo }}.">Censo {{ meta.versao_censo }}</div>
  </div>

  <div class="kpi-card">
    <div class="kpi-valor">{{ d.municipios_oferta or '—' }}</div>
    <div class="kpi-label">Municípios c/ oferta</div>
    <div class="kpi-fonte" title="Municípios com ao menos 1 IES operante.">Censo {{ meta.versao_censo }}</div>
  </div>

  <div class="kpi-card critico">
    <div class="kpi-valor">{{ d.municipios_deserto or '—' }}</div>
    <div class="kpi-label">Desertos (de {{ d.municipios_total }})</div>
    <div class="kpi-fonte" title="Municípios sem nenhuma IES com Farmácia.">Censo {{ meta.versao_censo }}</div>
  </div>

</div>

<!-- Capacidade real: presencial vs EaD -->
{% if d.vagas_total_real is not none %}
<h2 class="section-title">Capacidade formativa real — presencial vs EaD</h2>
<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px">
  Vagas EaD são atribuídas ao estado-sede da mantenedora (join Censo→Cadastro IES).
  O indicador "Vagas (operante)" acima reflete apenas a oferta <strong>presencial</strong>;
  a capacidade total inclui a EaD.
</p>
<div class="kpi-grid">
  <div class="kpi-card">
    <div class="kpi-valor">{{ "{:,}".format(d.vagas_total_real or 0).replace(',','.') }}</div>
    <div class="kpi-label">Vagas totais (pres + EaD)</div>
    <div class="kpi-fonte" title="Soma de vagas presenciais e EaD (sede da mantenedora).">Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ "{:,}".format(d.vagas_presencial or 0).replace(',','.') }}</div>
    <div class="kpi-label">Vagas presenciais</div>
    <div class="kpi-fonte">{{ d.n_cursos_presencial or 0 }} cursos presenciais</div>
  </div>
  <div class="kpi-card {% if d.pct_ead is not none and d.pct_ead >= 70 %}critico{% endif %}">
    <div class="kpi-valor">{{ "{:,}".format(d.vagas_ead or 0).replace(',','.') }}</div>
    <div class="kpi-label">Vagas EaD</div>
    <div class="kpi-fonte">{{ d.n_cursos_ead or 0 }} cursos EaD (sede no estado)</div>
  </div>
  <div class="kpi-card {% if d.pct_ead is not none and d.pct_ead >= 70 %}critico{% endif %}">
    <div class="kpi-valor">{% if d.pct_ead is not none %}{{ "%.1f"|format(d.pct_ead) }}%{% else %}—{% endif %}</div>
    <div class="kpi-label">% EaD da capacidade</div>
    <div class="kpi-fonte" title="Fatia de vagas em modalidade a distância.">Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ d.mun_ead_only if d.mun_ead_only is not none else '—' }}</div>
    <div class="kpi-label">Municípios só com EaD</div>
    <div class="kpi-fonte" title="Municípios com polo EaD mas sem nenhum curso presencial.">Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card {% if d.taxa_retencao is not none and d.taxa_retencao < 9 %}critico{% endif %}">
    <div class="kpi-valor">{% if d.taxa_retencao is not none %}{{ "%.1f"|format(d.taxa_retencao) }}%{% else %}—{% endif %}</div>
    <div class="kpi-label">Conclusão (conc./matríc.)</div>
    <div class="kpi-fonte" title="Concluintes ÷ matriculados no ano (proxy de retenção pontual, não de coorte). Benchmark nacional ≈ 10%.">Censo {{ meta.versao_censo }}</div>
  </div>
</div>
{% endif %}

<!-- Densidade e alcance territorial -->
{% if d.vagas_por_100k is not none or d.ead_polos_municipios is not none %}
<h2 class="section-title">Densidade e alcance territorial</h2>
<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px">
  A densidade por habitante normaliza a capacidade pela população. O alcance da EaD
  conta os <strong>municípios-polo</strong> onde há entrega presencial de cursos a
  distância — revelando a penetração territorial que a contagem de vagas na sede esconde.
</p>
<div class="kpi-grid">
  <div class="kpi-card">
    <div class="kpi-valor">{% if d.vagas_por_100k is not none %}{{ "%.1f"|format(d.vagas_por_100k) }}{% else %}—{% endif %}</div>
    <div class="kpi-label">Vagas / 100 mil hab.</div>
    <div class="kpi-fonte" title="Vagas totais (pres + EaD) por 100 mil habitantes. População: estimativa IBGE {{ d.pop_ano }}.">IBGE {{ d.pop_ano }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{% if d.populacao %}{{ "{:,}".format(d.populacao).replace(',','.') }}{% else %}—{% endif %}</div>
    <div class="kpi-label">População</div>
    <div class="kpi-fonte" title="Estimativa populacional IBGE.">IBGE {{ d.pop_ano }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ d.ead_polos_municipios if d.ead_polos_municipios is not none else '—' }}</div>
    <div class="kpi-label">Municípios c/ polo EaD</div>
    <div class="kpi-fonte" title="Municípios do estado que recebem oferta EaD de Farmácia via polo (independente da sede da mantenedora).">Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ d.ead_polos_registros if d.ead_polos_registros is not none else '—' }}</div>
    <div class="kpi-label">Polos EaD (registros)</div>
    <div class="kpi-fonte" title="Total de registros de polo EaD de Farmácia no estado.">Censo {{ meta.versao_censo }}</div>
  </div>
</div>
{% endif %}

<!-- Concentração de mercado -->
<h2 class="section-title">Estrutura de mercado</h2>
<div class="kpi-grid">
  <div class="kpi-card">
    <div class="kpi-valor">{% if d.HHI is not none %}{{ "%.4f"|format(d.HHI) }}{% else %}—{% endif %}</div>
    <div class="kpi-label">HHI (por IES)</div>
    <div class="kpi-fonte" title="Herfindahl-Hirschman Index por IES. 0=perfeita dispersão, 1=monopólio.">Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card {% if d.HHI_mantenedora is not none and d.HHI_mantenedora >= 0.25 %}critico{% endif %}">
    <div class="kpi-valor">{% if d.HHI_mantenedora is not none %}{{ "%.4f"|format(d.HHI_mantenedora) }}{% else %}—{% endif %}</div>
    <div class="kpi-label">HHI (por mantenedora)</div>
    <div class="kpi-fonte" title="HHI por grupo mantenedor (CO_MANTENEDORA) — captura conglomerados que controlam várias IES. {{ d.n_mantenedoras or 0 }} mantenedoras.">Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{% if d.CR2 is not none %}{{ "%.1f"|format(d.CR2 * 100) }}%{% else %}—{% endif %}</div>
    <div class="kpi-label">CR2 (2 maiores IES)</div>
    <div class="kpi-fonte" title="Fatia de vagas das 2 maiores IES.">Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{% if d.CR10 is not none %}{{ "%.1f"|format(d.CR10 * 100) }}%{% else %}—{% endif %}</div>
    <div class="kpi-label">CR10 (10 maiores IES)</div>
    <div class="kpi-fonte" title="Fatia de vagas das 10 maiores IES.">Censo {{ meta.versao_censo }}</div>
  </div>
  {% if d.CC is not none %}
  <div class="kpi-card">
    <div class="kpi-valor">{{ "%.2f"|format(d.CC) }}</div>
    <div class="kpi-label">CC (Conc. do Curso)</div>
    <div class="kpi-fonte" title="Conceito do Curso — média dos cursos avaliados no ENADE.">ENADE {{ meta.versao_censo }}</div>
  </div>
  {% endif %}
</div>

<!-- Qualidade ENADE -->
{% if d.CC is not none or d.ENADE is not none %}
<h2 class="section-title">Qualidade (ENADE 2023)
  <span style="display:inline-block;font-size:0.68rem;font-weight:600;color:#8a5a00;background:#fff3cd;border:1px solid #ffe08a;border-radius:10px;padding:2px 8px;vertical-align:middle;margin-left:8px"
        title="O ciclo ENADE de Farmácia é trienal. O resultado mais recente é de 2023 (publicado em abr/2025); o próximo ciclo ainda não foi divulgado. Os indicadores CC, ENADE, IDD e CPC referem-se a 2023, enquanto vagas/municípios são do Censo {{ meta.versao_censo }}.">
    ⚠ Ciclo 2023 (trienal) — não sincronizado com o Censo {{ meta.versao_censo }}
  </span>
</h2>
<div class="kpi-grid">
  <div class="kpi-card">
    <div class="kpi-valor">{{ "%.2f"|format(d.CC) if d.CC is not none else '—' }}</div>
    <div class="kpi-label">CC (média UF)</div>
    <div class="kpi-fonte" title="Conceito do Curso ENADE, escala 1–5.">ENADE</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ "%.2f"|format(d.ENADE) if d.ENADE is not none else '—' }}</div>
    <div class="kpi-label">ENADE (média UF)</div>
    <div class="kpi-fonte">ENADE</div>
  </div>
  <div class="kpi-card {% if d.IDD is not none %}{% if d.IDD >= 2.7 %}bom{% elif d.IDD < 2.0 %}critico{% endif %}{% else %}nodata{% endif %}">
    <div class="kpi-valor">{{ "%.2f"|format(d.IDD) if d.IDD is not none else '—' }}</div>
    <div class="kpi-label">IDD (média UF)</div>
    <div class="kpi-fonte" title="Indicador de Diferença entre Desempenhos Esperado e Observado (escala contínua 0–5). Mede o valor agregado pelo curso, controlando o perfil de ingresso. Média ponderada por concluintes. Fonte: INEP, CPC 2023.">CPC INEP 2023</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ "%.2f"|format(d.CPC_cont) if d.CPC_cont is not none else '—' }}</div>
    <div class="kpi-label">CPC (média UF)</div>
    <div class="kpi-fonte" title="Conceito Preliminar de Curso contínuo (0–5) — combina ENADE, IDD, corpo docente e infraestrutura. Fonte: INEP, CPC 2023.">CPC INEP 2023</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ d.vagas_avaliadas or '—' }}</div>
    <div class="kpi-label">Vagas avaliadas</div>
    <div class="kpi-fonte" title="Vagas em cursos que participaram do ENADE.">ENADE 2023</div>
  </div>
</div>
{% endif %}

<!-- Corpo docente (CPC 2023) -->
{% if d.pct_doc_doutores is not none or d.pct_doc_mestres is not none %}
<h2 class="section-title">Qualificação do corpo docente (CPC 2023)</h2>
<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px">
  Proporções reais extraídas da Planilha de Divulgação do CPC do INEP, ponderadas
  por concluintes participantes nos {{ d.n_cursos_docente or 0 }} cursos avaliados em {{ nome_uf }}.
</p>
<div class="kpi-grid">
  <div class="kpi-card {% if d.pct_doc_doutores is not none %}{% if d.pct_doc_doutores >= 60 %}bom{% elif d.pct_doc_doutores < 40 %}critico{% endif %}{% endif %}">
    <div class="kpi-valor">{% if d.pct_doc_doutores is not none %}{{ "%.1f"|format(d.pct_doc_doutores) }}%{% else %}—{% endif %}</div>
    <div class="kpi-label">Doutores</div>
    <div class="kpi-fonte" title="% de docentes com doutorado. Fonte: INEP, CPC 2023 (Nota Bruta - Doutores).">CPC INEP 2023</div>
  </div>
  <div class="kpi-card {% if d.pct_doc_mestres is not none and d.pct_doc_mestres >= 90 %}bom{% endif %}">
    <div class="kpi-valor">{% if d.pct_doc_mestres is not none %}{{ "%.1f"|format(d.pct_doc_mestres) }}%{% else %}—{% endif %}</div>
    <div class="kpi-label">Mestres ou mais</div>
    <div class="kpi-fonte" title="% de docentes com titulação mínima de mestre (inclui doutores). Fonte: INEP, CPC 2023.">CPC INEP 2023</div>
  </div>
  <div class="kpi-card {% if d.pct_doc_regime is not none and d.pct_doc_regime >= 90 %}bom{% endif %}">
    <div class="kpi-valor">{% if d.pct_doc_regime is not none %}{{ "%.1f"|format(d.pct_doc_regime) }}%{% else %}—{% endif %}</div>
    <div class="kpi-label">Regime integral/parcial</div>
    <div class="kpi-fonte" title="% de docentes em regime de trabalho integral ou parcial (não horista). Fonte: INEP, CPC 2023 (Nota Bruta - Regime de Trabalho).">CPC INEP 2023</div>
  </div>
</div>
{% endif %}

<!-- Mapa municipal -->
<h2 class="section-title">Mapa Municipal — {{ sigla }}</h2>
<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px">
  <span style="display:inline-block;width:14px;height:14px;background:#2E5496;border-radius:2px;vertical-align:middle;margin-right:4px"></span> Com oferta formativa &nbsp;
  <span style="display:inline-block;width:14px;height:14px;background:#C9CDD2;border-radius:2px;vertical-align:middle;margin-right:4px"></span> Deserto farmacêutico
</p>
<div id="mapa-uf" aria-label="Mapa dos municípios de {{ sigla }}"></div>

<!-- Lista de municípios -->
<h2 class="section-title">Municípios com oferta formativa ({{ d.municipios_oferta }})</h2>
{% if tem_drill %}
<p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:10px">
  Clique no município para ver cursos, IES e vagas detalhados.
</p>
{% endif %}
<div class="tabela-wrap">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Município</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      {% for mun in municipios_com_oferta %}
      <tr {% if tem_drill %}onclick="window.location='{{ depth }}municipio/{{ sigla }}/{{ mun | upper | replace(' ','_') | replace('/','_') }}.html'" style="cursor:pointer"{% endif %}>
        <td style="color:var(--text-muted);width:40px">{{ loop.index }}</td>
        <td>
          {% if tem_drill %}
          <a href="{{ depth }}municipio/{{ sigla }}/{{ mun | upper | replace(' ','_') | replace('/','_') }}.html">
            {{ mun | title }}
          </a>
          {% else %}
          {{ mun | title }}
          {% endif %}
        </td>
        <td><span style="color:var(--swot-strength);font-weight:600">✓ Com oferta</span></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<!-- SWOT (gerado por regras baseadas nos indicadores) -->
<h2 class="section-title">Análise SWOT — {{ sigla }}</h2>
<div class="swot-grid">
  <div class="swot-card swot-strength">
    <h3>Forças</h3>
    <ul>
      {% for item in swot.forcas %}<li>{{ item }}</li>{% endfor %}
    </ul>
  </div>
  <div class="swot-card swot-weakness">
    <h3>Fraquezas</h3>
    <ul>
      {% for item in swot.fraquezas %}<li>{{ item }}</li>{% endfor %}
    </ul>
  </div>
  <div class="swot-card swot-opportunity">
    <h3>Oportunidades</h3>
    <ul>
      {% for item in swot.oportunidades %}<li>{{ item }}</li>{% endfor %}
    </ul>
  </div>
  <div class="swot-card swot-threat">
    <h3>Ameaças</h3>
    <ul>
      {% for item in swot.ameacas %}<li>{{ item }}</li>{% endfor %}
    </ul>
  </div>
</div>

<!-- Proveniência completa -->
<details style="margin-bottom:24px">
  <summary style="cursor:pointer;font-size:0.875rem;color:var(--blue);padding:8px 0">
    Proveniência dos dados — {{ sigla }}
  </summary>
  <div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px;margin-top:8px;font-size:0.8rem">
    <table style="font-size:0.8rem">
      <tr><th style="padding:4px 8px;text-align:left">Indicador</th><th style="padding:4px 8px;text-align:left">Fonte</th><th style="padding:4px 8px;text-align:left">Extração</th></tr>
      <tr><td style="padding:4px 8px">ICT, vagas, municípios</td><td>INEP/Censo {{ meta.versao_censo }}</td><td>{{ meta.data_extracao }}</td></tr>
      <tr><td style="padding:4px 8px">CC, ENADE</td><td>INEP/ENADE 2023</td><td>{{ meta.data_extracao }}</td></tr>
      <tr><td style="padding:4px 8px">IDD, CPC, vagas avaliadas</td><td>INEP/CPC 2023 (CPC_2023.xlsx)</td><td>2025-04-11</td></tr>
      <tr><td style="padding:4px 8px">População, vagas/100k</td><td>IBGE — estimativa {{ d.pop_ano }} (API agregados 6579)</td><td>{{ meta.data_extracao }}</td></tr>
      <tr><td style="padding:4px 8px">Alcance EaD (polos)</td><td>INEP/Censo {{ meta.versao_censo }} (registros de polo)</td><td>{{ meta.data_extracao }}</td></tr>
      <tr><td style="padding:4px 8px">Farmácia Popular (municípios_fp)</td><td>Min. Saúde / dados.gov.br</td><td>{{ meta.data_extracao }}</td></tr>
    </table>
  </div>
</details>

{% endblock %}

{% block scripts %}
<script>
const DADOS_UF = {{ dados_uf_json }};
const META = {{ meta_json }};
const MUNICIPIOS_COM_OFERTA = {{ municipios_com_oferta_json }};
const MUNICIPIOS_OFERTA_CODS = {{ municipios_oferta_cods_json }};
const MUNICIPIOS_MAPA = {{ municipios_mapa_json }};
const CODIGO_IBGE_UF = "{{ codigo_ibge }}";
const SIGLA_UF = "{{ sigla }}";
const GEO_BASE = window._GEO_BASE || '';

document.addEventListener('DOMContentLoaded', () => {
  iniciarMapaUF(CODIGO_IBGE_UF, MUNICIPIOS_COM_OFERTA, MUNICIPIOS_OFERTA_CODS, MUNICIPIOS_MAPA, SIGLA_UF);
});

function exportarUFCSV() {
  const cols = ['UF','vagas_total','vagas_capital','municipios_oferta','municipios_deserto',
                 'ICT','IAF','ICON','E','HHI','CR2','CR10','CC','ENADE','IDD'];
  const linha = cols.map(c => c === 'UF' ? '{{ sigla }}' : (DADOS_UF[c] ?? '')).join(';');
  baixarArquivo(cols.join(';') + '\n' + linha, 'observatorio_{{ sigla }}.csv', 'text/csv;charset=utf-8');
}
</script>
{% endblock %}
