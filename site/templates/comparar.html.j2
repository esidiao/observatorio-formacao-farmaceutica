{% extends "base.html.j2" %}

{% block title %}Comparar UFs — Observatório Nacional da Formação Farmacêutica{% endblock %}

{% block breadcrumb %}
<a href="{{ depth }}index.html">Início</a>
<span class="sep">›</span>
<span class="active">Comparar UFs</span>
{% endblock %}

{% block content %}

<h2 class="section-title" style="margin-bottom:6px">Comparação entre UFs</h2>
<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:20px">
  Selecione as UFs para comparar. Os gráficos e a tabela atualizam automaticamente.
</p>

<!-- Seletor de UFs -->
<div class="toolbar" style="flex-wrap:wrap;gap:8px;margin-bottom:20px">
  <label style="font-weight:600;color:var(--navy);font-size:0.875rem">Selecionar UFs:</label>
  <div id="uf-chips" style="display:flex;flex-wrap:wrap;gap:6px">
    {% for sigla in todas_ufs %}
    <button
      class="uf-chip btn outline"
      data-uf="{{ sigla }}"
      onclick="toggleUF('{{ sigla }}')"
      style="padding:4px 10px;font-size:0.8rem;font-family:var(--font-mono);font-weight:700"
    >{{ sigla }}</button>
    {% endfor %}
  </div>
  <div style="flex:1;min-width:100%"></div>
  <button class="btn" onclick="selecionarTodos()" style="font-size:0.8rem">Todos</button>
  <button class="btn outline" onclick="limparSelecao()" style="font-size:0.8rem">Limpar</button>
  <div style="display:flex;align-items:center;gap:8px;margin-left:auto">
    <label style="font-size:0.875rem;font-weight:600">Indicador:</label>
    <select id="sel-ind" onchange="atualizarGraficos()" style="font-size:0.875rem">
      <optgroup label="Território & equidade">
        <option value="ICT">ICT — Concentração Territorial (↓ melhor)</option>
        <option value="E">E — Equidade (↑ melhor)</option>
        <option value="ICON">ICON — Cobertura Assistencial (↑)</option>
        <option value="ICON_adj">ICON-deserto — FP em desertos (↑)</option>
        <option value="vagas_por_100k">Vagas / 100 mil hab.</option>
        <option value="ead_polos_municipios">Municípios c/ polo EaD</option>
      </optgroup>
      <optgroup label="Qualidade (ENADE/CPC 2023)">
        <option value="IAF">IAF — Adequação Formativa (↑ melhor)</option>
        <option value="IDD">IDD — Valor agregado (↑ melhor)</option>
        <option value="CPC_cont">CPC — Conceito Preliminar (↑ melhor)</option>
      </optgroup>
      <optgroup label="Capacidade & mercado">
        <option value="vagas_total_real">Vagas totais (pres + EaD)</option>
        <option value="vagas_total">Vagas presenciais</option>
        <option value="pct_ead">% EaD da capacidade (↓ melhor)</option>
        <option value="taxa_retencao">Taxa de conclusão (↑)</option>
        <option value="HHI">HHI — por IES (↓ melhor)</option>
        <option value="HHI_mantenedora">HHI — por mantenedora (↓ melhor)</option>
      </optgroup>
    </select>
  </div>
</div>

<!-- Gráfico de barras -->
<h2 class="section-title">Gráfico comparativo</h2>
<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:20px;margin-bottom:28px">
  <canvas id="grafico-barras" height="100"></canvas>
</div>

<!-- Tabela comparativa -->
<h2 class="section-title">Tabela de comparação</h2>
<div class="tabela-wrap">
  <table id="tabela-comp">
    <thead>
      <tr>
        <th>UF</th>
        <th title="Vagas totais: presenciais + EaD (sede da mantenedora)">Vagas totais</th>
        <th title="Vagas por 100 mil habitantes (IBGE)">/100k</th>
        <th title="% das vagas em EaD">% EaD</th>
        <th>ICT ↓</th>
        <th>E</th>
        <th>IAF ↑</th>
        <th title="IDD — valor agregado pelo curso (ENADE/CPC 2023)">IDD ↑</th>
        <th title="Taxa de conclusão (concluintes/matrículas)">Concl. %</th>
        <th title="ICON-deserto — Farmácia Popular em desertos">ICON-d</th>
        <th title="HHI por mantenedora">HHI-m</th>
        <th title="Municípios c/ polo EaD">Polos</th>
        <th>Desertos</th>
      </tr>
    </thead>
    <tbody id="tbody-comp"></tbody>
  </table>
</div>

<div id="msg-vazio" style="text-align:center;padding:32px;color:var(--text-muted);display:none">
  Selecione ao menos uma UF acima para comparar.
</div>

<!-- Radar chart -->
<h2 class="section-title" style="margin-top:20px">Radar de indicadores (normalizado)</h2>
<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:20px;margin-bottom:28px;max-width:600px">
  <canvas id="grafico-radar" height="120"></canvas>
</div>

{% endblock %}

{% block scripts %}
<script>
const TODOS_DADOS = {{ dados_ufs_json }};
let selecionados = new Set(['GO', 'SP', 'MG', 'RJ', 'PR']); // padrão inicial

let barChart = null;
let radarChart = null;

function toggleUF(sigla) {
  if (selecionados.has(sigla)) {
    selecionados.delete(sigla);
  } else {
    selecionados.add(sigla);
  }
  atualizarChips();
  atualizarGraficos();
}

function selecionarTodos() {
  Object.keys(TODOS_DADOS).forEach(k => selecionados.add(k));
  atualizarChips();
  atualizarGraficos();
}

function limparSelecao() {
  selecionados.clear();
  atualizarChips();
  atualizarGraficos();
}

function atualizarChips() {
  document.querySelectorAll('.uf-chip').forEach(btn => {
    const uf = btn.dataset.uf;
    if (selecionados.has(uf)) {
      btn.style.background = 'var(--blue)';
      btn.style.color = '#fff';
    } else {
      btn.style.background = '';
      btn.style.color = '';
    }
  });
}

function atualizarGraficos() {
  const indicador = document.getElementById('sel-ind').value;
  const ufs = [...selecionados].sort();

  if (ufs.length === 0) {
    document.getElementById('msg-vazio').style.display = 'block';
    document.getElementById('tabela-comp').style.display = 'none';
    return;
  }
  document.getElementById('msg-vazio').style.display = 'none';
  document.getElementById('tabela-comp').style.display = '';

  const labels = ufs;
  const valores = ufs.map(u => TODOS_DADOS[u]?.[indicador] ?? null);
  const cores = ufs.map(u => {
    const v = TODOS_DADOS[u]?.[indicador];
    return getCor(indicador, v);
  });

  // Gráfico de barras
  const ctxBar = document.getElementById('grafico-barras').getContext('2d');
  if (barChart) barChart.destroy();
  barChart = new Chart(ctxBar, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: indicador,
        data: valores,
        backgroundColor: cores,
        borderColor: cores.map(c => c + 'cc'),
        borderWidth: 1,
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => {
              const v = ctx.raw;
              const m = INDICADOR_META[indicador] || { label: indicador };
              return v !== null ? `${m.label}: ${fmtIndicador(indicador, v)}` : 'sem dados';
            }
          }
        }
      },
      scales: {
        y: { beginAtZero: indicador !== 'IAF' && indicador !== 'IDD' && indicador !== 'CPC_cont' }
      }
    }
  });

  // Tabela
  const tbody = document.getElementById('tbody-comp');
  tbody.innerHTML = '';
  ufs.forEach(sigla => {
    const d = TODOS_DADOS[sigla] || {};
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><a href="uf/${sigla}.html"><span class="uf-tag">${sigla}</span></a></td>
      <td><strong>${fmtIndicador('vagas_total_real', d.vagas_total_real ?? d.vagas_total)}</strong></td>
      <td>${fmtIndicador('vagas_por_100k', d.vagas_por_100k)}</td>
      <td>${d.pct_ead != null ? fmtIndicador('pct_ead', d.pct_ead) + '%' : '—'}</td>
      <td class="${valClass('ICT', d.ICT)}">${fmtIndicador('ICT', d.ICT)}</td>
      <td>${fmtIndicador('E', d.E)}</td>
      <td class="${valClass('IAF', d.IAF)}">${fmtIndicador('IAF', d.IAF)}</td>
      <td>${fmtIndicador('IDD', d.IDD)}</td>
      <td>${fmtIndicador('taxa_retencao', d.taxa_retencao)}</td>
      <td>${fmtIndicador('ICON_adj', d.ICON_adj)}</td>
      <td>${fmtIndicador('HHI_mantenedora', d.HHI_mantenedora)}</td>
      <td>${d.ead_polos_municipios ?? '—'}</td>
      <td>${d.municipios_deserto ?? '—'}</td>
    `;
    tbody.appendChild(tr);
  });

  // Radar (normalizado, máx 5 UFs para legibilidade)
  const ufsRadar = ufs.slice(0, 8);
  const ctxRadar = document.getElementById('grafico-radar').getContext('2d');
  if (radarChart) radarChart.destroy();

  const PALETA = ['#2E5496','#B07D22','#3F6B2E','#B23A2E','#8B5CF6','#06B6D4','#F59E0B','#10B981'];

  radarChart = new Chart(ctxRadar, {
    type: 'radar',
    data: {
      labels: ['ICT (inv)', 'IAF/100', 'IDD/5', 'ICON/15', '1-HHI mant.', 'E', 'Concl./20'],
      datasets: ufsRadar.map((sigla, i) => {
        const d = TODOS_DADOS[sigla] || {};
        const num = v => (v !== null && v !== undefined) ? v : null;
        return {
          label: sigla,
          data: [
            d.ICT != null ? 1 - d.ICT : null,                          // ICT invertido: maior = melhor
            d.IAF != null ? d.IAF / 100 : null,
            d.IDD != null ? Math.min(d.IDD / 5, 1) : null,
            d.ICON != null ? Math.min(d.ICON / 15, 1) : null,
            d.HHI_mantenedora != null ? 1 - d.HHI_mantenedora : null,
            num(d.E),
            d.taxa_retencao != null ? Math.min(d.taxa_retencao / 20, 1) : null,
          ],
          borderColor: PALETA[i % PALETA.length],
          backgroundColor: PALETA[i % PALETA.length] + '22',
          borderWidth: 2,
          pointRadius: 3,
        };
      })
    },
    options: {
      responsive: true,
      scales: {
        r: { min: 0, max: 1, ticks: { stepSize: 0.25, font: { size: 10 } } }
      },
      plugins: {
        legend: { position: 'bottom', labels: { font: { size: 11 } } }
      }
    }
  });
}

// Inicializar
document.addEventListener('DOMContentLoaded', () => {
  atualizarChips();
  atualizarGraficos();
});
</script>
{% endblock %}
