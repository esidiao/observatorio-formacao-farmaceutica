{% extends "base.html.j2" %}

{% block title %}Comparar UFs — Observatório Nacional da Formação Farmacêutica{% endblock %}

{% block breadcrumb %}
<a href="{{ depth }}index.html">Início</a>
<span class="sep">›</span>
<span class="active">Comparar UFs</span>
{% endblock %}

{% block content %}

<h2 class="section-title" style="margin-bottom:6px">Comparação entre UFs</h2>
<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:20px">
  Escolha as <strong>UFs</strong> e os <strong>indicadores</strong> que deseja comparar.
  A tabela e o radar se adaptam à sua seleção; o gráfico de barras destaca um indicador por vez.
</p>

<!-- Seletor de UFs -->
<div class="toolbar" style="flex-wrap:wrap;gap:8px;margin-bottom:14px">
  <label style="font-weight:600;color:var(--navy);font-size:0.875rem">UFs:</label>
  <div id="uf-chips" style="display:flex;flex-wrap:wrap;gap:6px">
    {% for sigla in todas_ufs %}
    <button class="uf-chip btn outline" data-uf="{{ sigla }}" onclick="toggleUF('{{ sigla }}')"
      style="padding:4px 10px;font-size:0.8rem;font-family:var(--font-mono);font-weight:700">{{ sigla }}</button>
    {% endfor %}
  </div>
  <div style="flex:1;min-width:100%"></div>
  <button class="btn" onclick="selecionarTodos()" style="font-size:0.8rem">Todas</button>
  <button class="btn outline" onclick="limparSelecao()" style="font-size:0.8rem">Limpar UFs</button>
</div>

<!-- Seletor de KPIs -->
<div class="toolbar" style="flex-direction:column;align-items:stretch;gap:10px;margin-bottom:20px">
  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
    <label style="font-weight:600;color:var(--navy);font-size:0.875rem">Indicadores a comparar:</label>
    <span id="kpi-contador" style="font-size:0.78rem;color:var(--text-muted)"></span>
    <span style="flex:1"></span>
    <button class="btn outline" style="font-size:0.76rem;padding:4px 10px" onclick="presetKPIs('Qualidade')">Qualidade</button>
    <button class="btn outline" style="font-size:0.76rem;padding:4px 10px" onclick="presetKPIs('Acesso & equidade')">Acesso</button>
    <button class="btn outline" style="font-size:0.76rem;padding:4px 10px" onclick="presetKPIs('Capacidade')">Capacidade</button>
    <button class="btn outline" style="font-size:0.76rem;padding:4px 10px" onclick="limparKPIs()">Limpar KPIs</button>
  </div>
  <div id="kpi-chips"></div>
</div>

<!-- Seletor de modalidade -->
<div class="toolbar" style="gap:10px;margin-bottom:8px;align-items:center;flex-wrap:wrap">
  <label style="font-weight:600;color:var(--navy);font-size:0.875rem">Modalidade dos cursos:</label>
  <div id="mod-toggle" style="display:flex;gap:6px">
    <button class="mod-btn btn outline" data-mod="todas" onclick="setModalidade('todas')" style="font-size:0.8rem;padding:4px 12px">Todas</button>
    <button class="mod-btn btn outline" data-mod="presencial" onclick="setModalidade('presencial')" style="font-size:0.8rem;padding:4px 12px">Presencial</button>
    <button class="mod-btn btn outline" data-mod="ead" onclick="setModalidade('ead')" style="font-size:0.8rem;padding:4px 12px">EaD</button>
  </div>
  <span id="mod-nota" style="font-size:0.78rem;color:var(--text-muted)"></span>
</div>

<!-- Gráfico de barras (um indicador) -->
<h2 class="section-title">Gráfico de barras — um indicador</h2>
<div class="toolbar" style="margin-bottom:10px">
  <label style="font-size:0.875rem;font-weight:600">Indicador no gráfico:</label>
  <select id="sel-ind" onchange="renderTudo()" style="font-size:0.875rem"></select>
</div>
<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:20px;margin-bottom:28px">
  <canvas id="grafico-barras" height="100"></canvas>
</div>

<!-- Tabela comparativa (dinâmica) -->
<h2 class="section-title">Tabela de comparação</h2>
<div class="tabela-wrap">
  <table id="tabela-comp">
    <thead><tr id="comp-thead-row"></tr></thead>
    <tbody id="tbody-comp"></tbody>
  </table>
</div>

<div id="msg-vazio" style="text-align:center;padding:32px;color:var(--text-muted);display:none">
  Selecione ao menos uma UF e um indicador para comparar.
</div>

<!-- Radar (dinâmico, normalizado) -->
<h2 class="section-title" style="margin-top:20px">Radar de indicadores (normalizado)</h2>
<p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:10px">
  Cada eixo é um indicador selecionado, normalizado de 0 a 1 onde <strong>mais distante do centro = melhor</strong>
  (indicadores "menor é melhor" são invertidos; descritivos seguem a própria escala).
</p>
<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:20px;margin-bottom:28px;max-width:640px">
  <canvas id="grafico-radar" height="120"></canvas>
</div>

{% endblock %}

{% block scripts %}
<script>
const TODOS_DADOS = {{ dados_ufs_json }};
let selecionados = new Set(['GO', 'SP', 'MG', 'RJ', 'PR']);
let kpisSelecionados = new Set(['ICT', 'IAF', 'IDD', 'vagas_por_100k', 'pct_doc_doutores', 'taxa_retencao']);
let modalidade = 'todas';   // 'todas' | 'presencial' | 'ead'

let barChart = null, radarChart = null;
let sortKey = null, sortDir = 'desc';

/* Conjunto de chaves que possuem desdobramento por modalidade (memoizado). */
const KEYS_MODALIDADE = (() => {
  const s = new Set();
  Object.values(TODOS_DADOS).forEach(d => {
    const pm = d && d.por_modalidade;
    if (pm) ['presencial', 'ead'].forEach(m => pm[m] && Object.keys(pm[m]).forEach(k => s.add(k)));
  });
  return s;
})();
function temModalidade(key) { return KEYS_MODALIDADE.has(key); }

/* Valor de um KPI para uma UF, respeitando a modalidade selecionada.
   - chave desdobrável: usa o valor da modalidade (null se a UF não tem essa
     modalidade avaliada — evita exibir o total como se fosse da modalidade);
   - chave não desdobrável (território/equidade): mostra o total. */
function V(uf, key) {
  const d = TODOS_DADOS[uf] || {};
  if (modalidade !== 'todas' && temModalidade(key)) {
    const pm = d.por_modalidade && d.por_modalidade[modalidade];
    return (pm && key in pm && pm[key] != null) ? pm[key] : null;
  }
  return d[key];
}

function setModalidade(m) {
  modalidade = m;
  document.querySelectorAll('.mod-btn').forEach(b => {
    const on = b.dataset.mod === m;
    b.style.background = on ? 'var(--blue)' : '';
    b.style.color = on ? '#fff' : '';
  });
  const nota = document.getElementById('mod-nota');
  if (m === 'ead') nota.textContent = '⚠ Qualidade EaD avaliada em apenas 9 UFs (ENADE 2023); demais aparecem sem dado. Indicadores territoriais mostram o total.';
  else if (m === 'presencial') nota.textContent = 'Indicadores sem versão por modalidade (território, equidade) mostram o total.';
  else nota.textContent = '';
  renderTudo();
}

// Catálogo de KPIs comparáveis: reaproveita o GLOSSARIO, filtrando aos campos
// numéricos presentes nos dados das UFs.
const CATALOGO = (typeof GLOSSARIO !== 'undefined' ? GLOSSARIO : [])
  .filter(g => Object.values(TODOS_DADOS).some(d => d && d[g.key] != null && !isNaN(Number(d[g.key]))));
const CAT_INFO = Object.fromEntries(CATALOGO.map(g => [g.key, g]));
const ORDEM_CAT = ['Território', 'Qualidade', 'Capacidade', 'Acesso & equidade', 'Mercado'];

/* ---------- Seletor de KPIs ---------- */
function renderKpiChips() {
  const root = document.getElementById('kpi-chips');
  let html = '';
  ORDEM_CAT.forEach(cat => {
    const itens = CATALOGO.filter(g => g.cat === cat);
    if (!itens.length) return;
    html += `<div style="margin-bottom:8px"><div style="font-size:0.68rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--gold);font-weight:700;margin-bottom:5px">${cat}</div><div style="display:flex;flex-wrap:wrap;gap:6px">`;
    itens.forEach(g => {
      const on = kpisSelecionados.has(g.key);
      html += `<button class="kpi-chip btn outline" data-kpi="${g.key}" onclick="toggleKPI('${g.key}')"
        style="padding:3px 9px;font-size:0.76rem;${on ? 'background:var(--blue);color:#fff' : ''}" title="${g.nome}">${g.sigla}</button>`;
    });
    html += `</div></div>`;
  });
  root.innerHTML = html;
  document.getElementById('kpi-contador').textContent = `(${kpisSelecionados.size} selecionados)`;
}

function toggleKPI(key) {
  if (kpisSelecionados.has(key)) kpisSelecionados.delete(key);
  else kpisSelecionados.add(key);
  renderKpiChips(); renderSelectBarra(); renderTudo();
}
function presetKPIs(cat) {
  kpisSelecionados = new Set(CATALOGO.filter(g => g.cat === cat).map(g => g.key));
  renderKpiChips(); renderSelectBarra(); renderTudo();
}
function limparKPIs() { kpisSelecionados.clear(); renderKpiChips(); renderSelectBarra(); renderTudo(); }

/* Dropdown do gráfico de barras = KPIs selecionados (ou todos, se nenhum) */
function renderSelectBarra() {
  const sel = document.getElementById('sel-ind');
  const anterior = sel.value;
  const keys = kpisSelecionados.size ? [...kpisSelecionados] : CATALOGO.map(g => g.key);
  sel.innerHTML = keys.map(k => `<option value="${k}">${(CAT_INFO[k] || {}).nome || k}</option>`).join('');
  if (keys.includes(anterior)) sel.value = anterior;
}

/* ---------- Seleção de UFs ---------- */
function toggleUF(s) { selecionados.has(s) ? selecionados.delete(s) : selecionados.add(s); atualizarChips(); renderTudo(); }
function selecionarTodos() { Object.keys(TODOS_DADOS).forEach(k => selecionados.add(k)); atualizarChips(); renderTudo(); }
function limparSelecao() { selecionados.clear(); atualizarChips(); renderTudo(); }
function atualizarChips() {
  document.querySelectorAll('.uf-chip').forEach(b => {
    const on = selecionados.has(b.dataset.uf);
    b.style.background = on ? 'var(--blue)' : '';
    b.style.color = on ? '#fff' : '';
  });
}

/* ---------- Ordenação ---------- */
function ordenarPor(key) {
  if (sortKey === key) sortDir = (sortDir === 'desc') ? 'asc' : 'desc';
  else { sortKey = key; sortDir = (key === 'sigla') ? 'asc' : 'desc'; }
  renderTabela();
}
function ordenarUFs(ufs) {
  const arr = [...ufs];
  if (!sortKey) return arr.sort();
  arr.sort((a, b) => {
    let va = (sortKey === 'sigla') ? a : V(a, sortKey);
    let vb = (sortKey === 'sigla') ? b : V(b, sortKey);
    const na = va == null, nb = vb == null;
    if (na && nb) return 0; if (na) return 1; if (nb) return -1;
    const cmp = (typeof va === 'string' || typeof vb === 'string')
      ? String(va).localeCompare(String(vb), 'pt-BR') : va - vb;
    return sortDir === 'asc' ? cmp : -cmp;
  });
  return arr;
}

/* ---------- Normalização p/ radar (0-1, maior = melhor) ---------- */
function normKPI(key, v, ufs) {
  if (v == null || isNaN(v)) return null;
  const m = INDICADOR_META[key] || {};
  let min = m.min, max = m.max;
  if (min == null || max == null) {
    const vals = ufs.map(u => V(u, key)).filter(x => x != null && !isNaN(x));
    if (!vals.length) return null;
    min = Math.min(...vals); max = Math.max(...vals);
  }
  if (max === min) return 0.5;
  let n = (v - min) / (max - min);
  if (m.maiorMelhor === false) n = 1 - n;
  return Math.max(0, Math.min(1, n));
}

/* ---------- Render principal ---------- */
function renderTudo() {
  const temUF = selecionados.size > 0, temKPI = kpisSelecionados.size > 0;
  document.getElementById('msg-vazio').style.display = (temUF && temKPI) ? 'none' : 'block';
  document.getElementById('tabela-comp').style.display = (temUF && temKPI) ? '' : 'none';
  renderBarra(); renderTabela(); renderRadar();
}

function renderBarra() {
  const ufs = [...selecionados].sort();
  const indicador = document.getElementById('sel-ind').value;
  const ctx = document.getElementById('grafico-barras').getContext('2d');
  if (barChart) barChart.destroy();
  if (!ufs.length || !indicador) return;
  const valores = ufs.map(u => V(u, indicador) ?? null);
  const cores = ufs.map(u => getCor(indicador, V(u, indicador)));
  const m = INDICADOR_META[indicador] || { label: indicador };
  const sufMod = modalidade !== 'todas' ? ` — ${modalidade === 'ead' ? 'EaD' : 'Presencial'}` : '';
  barChart = new Chart(ctx, {
    type: 'bar',
    data: { labels: ufs, datasets: [{ label: m.label, data: valores, backgroundColor: cores, borderWidth: 1 }] },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        title: { display: true, text: ((CAT_INFO[indicador] || {}).nome || indicador) + sufMod, font: { size: 13 } },
        tooltip: { callbacks: { label: c => c.raw != null ? `${m.label}: ${fmtIndicador(indicador, c.raw)}` : 'sem dados' } }
      },
      scales: { y: { beginAtZero: !['IAF', 'IDD', 'CPC_cont', 'cpc_org_didatico', 'cpc_infraestrutura', 'cpc_oportunidade'].includes(indicador) } }
    }
  });
}

function renderTabela() {
  const thead = document.getElementById('comp-thead-row');
  const tbody = document.getElementById('tbody-comp');
  const ufs = [...selecionados];
  const keys = [...kpisSelecionados];
  if (!ufs.length || !keys.length) { thead.innerHTML = ''; tbody.innerHTML = ''; return; }

  // Cabeçalho dinâmico (UF + KPIs selecionados), ordenável
  let th = `<th data-key="sigla" onclick="ordenarPor('sigla')" style="cursor:pointer;user-select:none">UF${sortKey === 'sigla' ? (sortDir === 'asc' ? ' ▲' : ' ▼') : ''}</th>`;
  keys.forEach(k => {
    const g = CAT_INFO[k] || { sigla: k, nome: k };
    const seta = sortKey === k ? (sortDir === 'asc' ? ' ▲' : ' ▼') : '';
    const bg = sortKey === k ? 'background:var(--blue)' : '';
    const mod = (modalidade !== 'todas' && temModalidade(k)) ? ' <span style="font-size:0.7em;opacity:0.85">●</span>' : '';
    th += `<th data-key="${k}" onclick="ordenarPor('${k}')" title="${g.nome}${(modalidade!=='todas'&&temModalidade(k))?' (valor por modalidade)':''} — clique para ordenar" style="cursor:pointer;user-select:none;${bg}">${g.sigla}${mod}${seta}</th>`;
  });
  thead.innerHTML = th;

  tbody.innerHTML = '';
  ordenarUFs(ufs).forEach(sigla => {
    let row = `<td><a href="uf/${sigla}.html"><span class="uf-tag">${sigla}</span></a></td>`;
    keys.forEach(k => {
      const val = V(sigla, k);
      const cls = (k === 'ICT' || k === 'IAF') ? valClass(k, val) : '';
      row += `<td class="${cls}">${fmtIndicador(k, val)}</td>`;
    });
    const tr = document.createElement('tr');
    tr.innerHTML = row;
    tbody.appendChild(tr);
  });
}

function renderRadar() {
  const ctx = document.getElementById('grafico-radar').getContext('2d');
  if (radarChart) radarChart.destroy();
  const ufs = [...selecionados].sort().slice(0, 8);
  const keys = [...kpisSelecionados];
  if (ufs.length < 1 || keys.length < 3) {  // radar precisa de ≥3 eixos
    return;
  }
  const PALETA = ['#2E5496', '#B07D22', '#3F6B2E', '#B23A2E', '#8B5CF6', '#06B6D4', '#F59E0B', '#10B981'];
  const labels = keys.map(k => {
    const m = INDICADOR_META[k] || {};
    const s = (CAT_INFO[k] || {}).sigla || k;
    return m.maiorMelhor === false ? s + ' (inv)' : s;
  });
  radarChart = new Chart(ctx, {
    type: 'radar',
    data: {
      labels,
      datasets: ufs.map((sigla, i) => ({
        label: sigla,
        data: keys.map(k => normKPI(k, V(sigla, k), ufs)),
        borderColor: PALETA[i % PALETA.length],
        backgroundColor: PALETA[i % PALETA.length] + '22',
        borderWidth: 2, pointRadius: 3,
      }))
    },
    options: {
      responsive: true,
      scales: { r: { min: 0, max: 1, ticks: { stepSize: 0.25, font: { size: 10 } } } },
      plugins: { legend: { position: 'bottom', labels: { font: { size: 11 } } } }
    }
  });
}

document.addEventListener('DOMContentLoaded', () => {
  renderKpiChips();
  renderSelectBarra();
  atualizarChips();
  setModalidade('todas');   // destaca botão e renderiza tudo
});
</script>
{% endblock %}
