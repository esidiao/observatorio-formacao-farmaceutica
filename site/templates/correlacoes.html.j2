{% extends "base.html.j2" %}

{% block title %}Correlações — Observatório Nacional da Formação Farmacêutica{% endblock %}
{% block meta_description %}Correlações entre indicadores da formação farmacêutica nos 27 estados: matriz de correlação e gráficos de dispersão interativos (qualificação docente, IDD, EaD, equidade).{% endblock %}

{% block breadcrumb %}
<a href="{{ depth }}index.html">Início</a>
<span class="sep">›</span>
<span class="active">Correlações</span>
{% endblock %}

{% block content %}

<h2 class="section-title" style="margin-bottom:6px">Correlações entre indicadores</h2>
<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:8px;max-width:80ch">
  Explore como os indicadores se relacionam entre as 27 UFs. Escolha dois indicadores para o
  gráfico de dispersão (cada ponto é um estado) ou clique numa célula da matriz.
</p>
<div class="legal-callout" style="background:var(--surface);border:1px solid var(--border);border-left:4px solid var(--gold);border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:0.83rem;max-width:80ch">
  <strong>Como ler com cuidado:</strong> correlação <strong>não é causalidade</strong>. A análise é
  por <strong>estado</strong> (n = 27) — relações no agregado podem não valer para cada curso
  (falácia ecológica). Use como <strong>exploração de hipóteses</strong>, não como prova.
</div>

<!-- Modalidade -->
<div class="toolbar" style="gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:12px">
  <label style="font-weight:600;color:var(--navy);font-size:0.875rem">Modalidade:</label>
  <div style="display:flex;gap:6px">
    <button class="modc-btn btn outline" data-mod="todas" onclick="setModCorr('todas')" style="font-size:0.8rem;padding:4px 12px">Todas</button>
    <button class="modc-btn btn outline" data-mod="presencial" onclick="setModCorr('presencial')" style="font-size:0.8rem;padding:4px 12px">Presencial</button>
    <button class="modc-btn btn outline" data-mod="ead" onclick="setModCorr('ead')" style="font-size:0.8rem;padding:4px 12px">EaD</button>
  </div>
  <span id="modc-nota" style="font-size:0.78rem;color:var(--text-muted)"></span>
</div>

<!-- Dispersão -->
<div class="toolbar" style="gap:12px;flex-wrap:wrap;margin-bottom:12px">
  <div style="display:flex;align-items:center;gap:8px">
    <label style="font-size:0.875rem;font-weight:600">Eixo X:</label>
    <select id="sel-x" onchange="renderScatter()" style="font-size:0.85rem"></select>
  </div>
  <div style="display:flex;align-items:center;gap:8px">
    <label style="font-size:0.875rem;font-weight:600">Eixo Y:</label>
    <select id="sel-y" onchange="renderScatter()" style="font-size:0.85rem"></select>
  </div>
  <button class="btn outline" onclick="trocarEixos()" style="font-size:0.8rem">⇄ Trocar</button>
</div>
<div id="corr-resumo" style="font-size:0.92rem;margin-bottom:10px"></div>
<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:20px;margin-bottom:32px">
  <canvas id="grafico-scatter" height="120"></canvas>
</div>

<!-- Matriz -->
<h2 class="section-title">Matriz de correlação (Pearson)</h2>
<p style="font-size:0.83rem;color:var(--text-muted);margin-bottom:12px">
  Azul = correlação positiva · vermelho = negativa · tom mais forte = relação mais intensa.
  Células <strong>esmaecidas em itálico</strong> = <strong>não significativas</strong> (p ≥ 0,05).
  Estrelas: <code>*</code> p&lt;0,05 · <code>**</code> p&lt;0,01 · <code>***</code> p&lt;0,001. Clique para ver a dispersão.
  <br><span style="font-size:0.78rem">⚠ Muitos testes simultâneos inflam falsos positivos (problema das comparações múltiplas) — trate como exploratório.</span>
</p>
<div class="tabela-wrap">
  <table id="matriz-corr" style="font-size:0.8rem"></table>
</div>

{% endblock %}

{% block scripts %}
<script>
const DADOS = {{ dados_ufs_json }};
const UFS = Object.keys(DADOS);

// Catálogo: reaproveita o GLOSSARIO; só indicadores numéricos presentes
const CAT = (typeof GLOSSARIO !== 'undefined' ? GLOSSARIO : [])
  .filter(g => UFS.some(u => DADOS[u] && DADOS[u][g.key] != null && !isNaN(Number(DADOS[u][g.key]))));
const INFO = Object.fromEntries(CAT.map(g => [g.key, g]));

// Indicadores-chave para a matriz
const MATRIZ_KEYS = ['IDD', 'CPC_cont', 'pct_doc_doutores', 'cpc_infraestrutura', 'taxa_retencao',
  'ICT', 'HHI_mantenedora', 'pct_ead', 'vagas_por_100k', 'pct_ppi', 'pct_financiamento', 'pct_mulheres']
  .filter(k => INFO[k]);

const NOMES_UF = (typeof NOMES_UF_MAPA !== 'undefined') ? NOMES_UF_MAPA : {};

// ---- Modalidade (presencial/EaD via por_modalidade) ----
let modCorr = 'todas';
const KEYS_MOD = (() => {
  const s = new Set();
  Object.values(DADOS).forEach(d => {
    const pm = d && d.por_modalidade;
    if (pm) ['presencial', 'ead'].forEach(m => pm[m] && Object.keys(pm[m]).forEach(k => s.add(k)));
  });
  return s;
})();
function val(uf, key) {
  const d = DADOS[uf] || {};
  if (modCorr !== 'todas' && KEYS_MOD.has(key)) {
    const pm = d.por_modalidade && d.por_modalidade[modCorr];
    return (pm && key in pm && pm[key] != null) ? pm[key] : null;
  }
  return d[key];
}
function setModCorr(m) {
  modCorr = m;
  document.querySelectorAll('.modc-btn').forEach(b => {
    const on = b.dataset.mod === m;
    b.style.background = on ? 'var(--blue)' : ''; b.style.color = on ? '#fff' : '';
  });
  const nota = document.getElementById('modc-nota');
  nota.textContent = m === 'ead'
    ? '⚠ Qualidade EaD avaliada em poucas UFs — amostra pequena, correlações tendem a não ser significativas.'
    : (m === 'presencial' ? 'Indicadores sem versão por modalidade (território/equidade) usam o total.' : '');
  renderScatter(); renderMatriz();
}

function pares(kx, ky) {
  const p = [];
  UFS.forEach(u => {
    const x = val(u, kx), y = val(u, ky);
    if (x != null && y != null && !isNaN(x) && !isNaN(y)) p.push([+x, +y, u]);
  });
  return p;
}

// ---- Estatística inferencial ----
function gammaln(x) {
  const c = [76.18009172947146, -86.50532032941677, 24.01409824083091,
    -1.231739572450155, 0.1208650973866179e-2, -0.5395239384953e-5];
  let y = x, t = x + 5.5; t -= (x + 0.5) * Math.log(t);
  let s = 1.000000000190015;
  for (let j = 0; j < 6; j++) s += c[j] / ++y;
  return -t + Math.log(2.5066282746310005 * s / x);
}
function betacf(a, b, x) {
  const FPMIN = 1e-30; let qab = a + b, qap = a + 1, qam = a - 1;
  let c = 1, d = 1 - qab * x / qap; if (Math.abs(d) < FPMIN) d = FPMIN; d = 1 / d; let h = d;
  for (let m = 1; m <= 200; m++) {
    const m2 = 2 * m;
    let aa = m * (b - m) * x / ((qam + m2) * (a + m2));
    d = 1 + aa * d; if (Math.abs(d) < FPMIN) d = FPMIN;
    c = 1 + aa / c; if (Math.abs(c) < FPMIN) c = FPMIN; d = 1 / d; h *= d * c;
    aa = -(a + m) * (qab + m) * x / ((a + m2) * (qap + m2));
    d = 1 + aa * d; if (Math.abs(d) < FPMIN) d = FPMIN;
    c = 1 + aa / c; if (Math.abs(c) < FPMIN) c = FPMIN; d = 1 / d;
    const del = d * c; h *= del; if (Math.abs(del - 1) < 3e-7) break;
  }
  return h;
}
function betai(a, b, x) {
  if (x <= 0) return 0; if (x >= 1) return 1;
  const bt = Math.exp(gammaln(a + b) - gammaln(a) - gammaln(b) + a * Math.log(x) + b * Math.log(1 - x));
  return x < (a + 1) / (a + b + 2) ? bt * betacf(a, b, x) / a : 1 - bt * betacf(b, a, 1 - x) / b;
}
// p-valor bicaudal do r de Pearson (teste t, df = n-2)
function pPearson(r, n) {
  if (n < 4 || Math.abs(r) >= 1) return n < 4 ? null : 0;
  const df = n - 2, t2 = r * r * df / (1 - r * r);
  return betai(df / 2, 0.5, df / (df + t2));
}
function estrelas(p) { return p == null ? '' : (p < 0.001 ? '***' : p < 0.01 ? '**' : p < 0.05 ? '*' : ''); }
// IC 95% de r por transformação de Fisher
function fisherCI(r, n) {
  if (n < 5 || Math.abs(r) >= 1) return null;
  const z = Math.atanh(r), se = 1 / Math.sqrt(n - 3);
  return [Math.tanh(z - 1.96 * se), Math.tanh(z + 1.96 * se)];
}
function pearson(p) {
  const n = p.length; if (n < 4) return null;
  const mx = p.reduce((s, a) => s + a[0], 0) / n, my = p.reduce((s, a) => s + a[1], 0) / n;
  let sxy = 0, sxx = 0, syy = 0;
  p.forEach(a => { sxy += (a[0] - mx) * (a[1] - my); sxx += (a[0] - mx) ** 2; syy += (a[1] - my) ** 2; });
  return (sxx && syy) ? sxy / Math.sqrt(sxx * syy) : null;
}
function corCorr(r) {
  if (r == null) return '#eee';
  const a = Math.min(1, Math.abs(r));
  const base = r >= 0 ? [33, 102, 172] : [178, 24, 43];   // azul / vermelho
  const mix = base.map(c => Math.round(255 - (255 - c) * a));
  return `rgb(${mix.join(',')})`;
}
function forca(r) {
  const a = Math.abs(r);
  return a >= 0.6 ? 'forte' : a >= 0.3 ? 'moderada' : 'fraca';
}

let scatter = null;

function popularSelects() {
  const opt = k => `<option value="${k}">${(INFO[k] || {}).nome || k}</option>`;
  const grupos = {};
  CAT.forEach(g => { (grupos[g.cat] = grupos[g.cat] || []).push(g.key); });
  let html = '';
  ['Território', 'Qualidade', 'Capacidade', 'Acesso & equidade', 'Mercado'].forEach(cat => {
    if (!grupos[cat]) return;
    html += `<optgroup label="${cat}">` + grupos[cat].map(opt).join('') + `</optgroup>`;
  });
  document.getElementById('sel-x').innerHTML = html;
  document.getElementById('sel-y').innerHTML = html;
  document.getElementById('sel-x').value = 'pct_doc_doutores';
  document.getElementById('sel-y').value = 'IDD';
}

function trocarEixos() {
  const x = document.getElementById('sel-x'), y = document.getElementById('sel-y');
  [x.value, y.value] = [y.value, x.value];
  renderScatter();
}

function renderScatter() {
  const kx = document.getElementById('sel-x').value, ky = document.getElementById('sel-y').value;
  const p = pares(kx, ky);
  const r = pearson(p);
  const nx = (INFO[kx] || {}).nome || kx, ny = (INFO[ky] || {}).nome || ky;

  // resumo textual
  const resumo = document.getElementById('corr-resumo');
  if (r == null) { resumo.innerHTML = `Dados insuficientes para correlacionar (n = ${p.length}).`; }
  else {
    const dir = r >= 0 ? 'positiva' : 'negativa';
    const cor = Math.abs(r) >= 0.6 ? 'var(--swot-strength)' : (Math.abs(r) >= 0.3 ? 'var(--gold)' : 'var(--text-muted)');
    const pv = pPearson(r, p.length), ci = fisherCI(r, p.length), st = estrelas(pv);
    const pTxt = pv == null ? '' : (pv < 0.001 ? 'p < 0,001' : 'p = ' + pv.toFixed(3).replace('.', ','));
    const signif = pv != null && pv < 0.05;
    resumo.innerHTML = `Correlação <strong style="color:${cor}">${dir} ${forca(r)}</strong> · `
      + `<strong>r = ${r.toFixed(2)}${st}</strong> (n = ${p.length}). `
      + `<span style="color:${signif ? 'var(--swot-strength)' : 'var(--swot-threat)'}">${pTxt}${signif ? ' — significativa' : ' — não significativa (p ≥ 0,05)'}</span> · `
      + (ci ? `<span style="color:var(--text-muted)">IC 95%: [${ci[0].toFixed(2)}; ${ci[1].toFixed(2)}] · </span>` : '')
      + `<span style="color:var(--text-muted)">r² = ${(r * r).toFixed(2)}.</span>`;
  }

  // reta de tendência (mínimos quadrados)
  let linha = [];
  if (p.length >= 2) {
    const n = p.length, mx = p.reduce((s, a) => s + a[0], 0) / n, my = p.reduce((s, a) => s + a[1], 0) / n;
    let sxx = 0, sxy = 0;
    p.forEach(a => { sxx += (a[0] - mx) ** 2; sxy += (a[0] - mx) * (a[1] - my); });
    const b = sxx ? sxy / sxx : 0, a0 = my - b * mx;
    const xs = p.map(a => a[0]); const x0 = Math.min(...xs), x1 = Math.max(...xs);
    linha = [{ x: x0, y: a0 + b * x0 }, { x: x1, y: a0 + b * x1 }];
  }

  const ctx = document.getElementById('grafico-scatter').getContext('2d');
  if (scatter) scatter.destroy();
  scatter = new Chart(ctx, {
    data: {
      datasets: [
        { type: 'scatter', label: 'UFs', data: p.map(a => ({ x: a[0], y: a[1], uf: a[2] })),
          backgroundColor: '#2E5496', pointRadius: 5, pointHoverRadius: 7 },
        { type: 'line', label: 'tendência', data: linha, borderColor: '#B07D22',
          borderDash: [6, 4], borderWidth: 2, pointRadius: 0, fill: false }
      ]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: c => c.raw.uf ? `${NOMES_UF[c.raw.uf] || c.raw.uf}: ${nx} ${fmtIndicador(kx, c.raw.x)} · ${ny} ${fmtIndicador(ky, c.raw.y)}` : '' } }
      },
      scales: {
        x: { title: { display: true, text: nx, font: { size: 11 } } },
        y: { title: { display: true, text: ny, font: { size: 11 } } }
      }
    },
    plugins: [{
      id: 'ufLabels',
      afterDatasetsDraw(chart) {
        const ctx = chart.ctx; ctx.save();
        ctx.font = '10px sans-serif'; ctx.fillStyle = '#16304F';
        chart.getDatasetMeta(0).data.forEach((pt, i) => {
          ctx.fillText(chart.data.datasets[0].data[i].uf, pt.x + 6, pt.y - 4);
        });
        ctx.restore();
      }
    }]
  });
}

function renderMatriz() {
  const tbl = document.getElementById('matriz-corr');
  const sig = k => (INFO[k] || {}).sigla || k;
  let html = '<thead><tr><th></th>' + MATRIZ_KEYS.map(k => `<th title="${(INFO[k] || {}).nome}" style="writing-mode:vertical-rl;transform:rotate(180deg);padding:4px;font-size:0.72rem">${sig(k)}</th>`).join('') + '</tr></thead><tbody>';
  MATRIZ_KEYS.forEach(kr => {
    html += `<tr><th style="text-align:left;padding:4px 8px;white-space:nowrap;font-size:0.72rem" title="${(INFO[kr] || {}).nome}">${sig(kr)}</th>`;
    MATRIZ_KEYS.forEach(kc => {
      if (kr === kc) { html += `<td style="background:#16304F"></td>`; return; }
      const pr = pares(kr, kc), r = pearson(pr);
      const pv = r == null ? null : pPearson(r, pr.length);
      const signif = pv != null && pv < 0.05;
      const txt = r == null ? '' : r.toFixed(2).replace('0.', '.').replace('-0.', '-.') + estrelas(pv);
      const escuro = r != null && Math.abs(r) >= 0.55;
      // não significativa: célula esmaecida e em itálico
      html += `<td onclick="abrirPar('${kc}','${kr}')" `
        + `title="${sig(kr)} × ${sig(kc)}: r=${r == null ? 's/d' : r.toFixed(2)}${pv == null ? '' : ', p=' + (pv < 0.001 ? '<0,001' : pv.toFixed(3))} (n=${pr.length})" `
        + `style="cursor:pointer;text-align:center;padding:5px;background:${corCorr(r)};color:${escuro ? '#fff' : '#222'};`
        + `font-size:0.72rem;${signif ? '' : 'opacity:0.45;font-style:italic'}">${txt}</td>`;
    });
    html += '</tr>';
  });
  tbl.innerHTML = html + '</tbody>';
}

function abrirPar(kx, ky) {
  document.getElementById('sel-x').value = kx;
  document.getElementById('sel-y').value = ky;
  renderScatter();
  document.getElementById('grafico-scatter').scrollIntoView({ behavior: 'smooth', block: 'center' });
}

document.addEventListener('DOMContentLoaded', () => {
  popularSelects();
  setModCorr('todas');   // destaca botão + renderiza scatter e matriz
});
</script>
{% endblock %}
