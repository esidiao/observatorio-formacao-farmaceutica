{% extends "base.html.j2" %}

{% block title %}Índice Sintético — Observatório Nacional da Formação Farmacêutica{% endblock %}
{% block meta_description %}Índice de Qualidade da Formação Farmacêutica (IQFF) por estado — índice composto e transparente com pesos ajustáveis e ranking das 27 UFs.{% endblock %}

{% block breadcrumb %}
<a href="{{ depth }}index.html">Início</a>
<span class="sep">›</span>
<span class="active">Índice Sintético</span>
{% endblock %}

{% block content %}

<h2 class="section-title" style="margin-bottom:6px">Índice de Qualidade da Formação (IQFF)</h2>
<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:8px;max-width:82ch">
  Um índice <strong>composto e transparente</strong> que resume seis dimensões num único valor de 0 a 100,
  ranqueando as 27 UFs. <strong>Ajuste os pesos</strong> abaixo e veja o ranking mudar — é a própria
  <strong>análise de sensibilidade</strong>: posições robustas pouco mudam; posições frágeis oscilam.
</p>
<div class="legal-callout" style="background:var(--surface);border:1px solid var(--border);border-left:4px solid var(--gold);border-radius:8px;padding:12px 16px;margin-bottom:18px;font-size:0.83rem;max-width:82ch">
  <strong>Método:</strong> cada dimensão é normalizada de 0 a 1 entre as UFs (mín–máx, sempre "maior = melhor")
  e combinada por <strong>média ponderada</strong>. O índice é <strong>relativo</strong> (compara UFs entre si),
  não uma nota absoluta. Pesos iguais por padrão.
</div>

<!-- Sliders de peso -->
<div class="toolbar" style="flex-direction:column;align-items:stretch;gap:10px;margin-bottom:18px">
  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
    <label style="font-weight:600;color:var(--navy);font-size:0.875rem">Pesos das dimensões:</label>
    <span style="flex:1"></span>
    <button class="btn outline" style="font-size:0.76rem;padding:4px 10px" onclick="presetPesos('iguais')">Pesos iguais</button>
    <button class="btn outline" style="font-size:0.76rem;padding:4px 10px" onclick="presetPesos('qualidade')">Foco qualidade</button>
    <button class="btn outline" style="font-size:0.76rem;padding:4px 10px" onclick="presetPesos('acesso')">Foco acesso</button>
  </div>
  <div id="sliders"></div>
</div>

<!-- Ranking -->
<div class="tabela-wrap">
  <table id="rank-tbl"></table>
</div>

{% endblock %}

{% block scripts %}
<script>
const DADOS = {{ dados_ufs_json }};
const UFS = Object.keys(DADOS);
const NOMES = (typeof NOMES_UF_MAPA !== 'undefined') ? NOMES_UF_MAPA : {};

// Dimensões do índice (key, rótulo, direção). HHI: menor é melhor → invertido.
const DIM = [
  { key: 'IDD',                rotulo: 'Qualidade (IDD)',        inv: false },
  { key: 'pct_doc_doutores',   rotulo: 'Corpo docente (doutores)', inv: false },
  { key: 'cpc_infraestrutura', rotulo: 'Infraestrutura',         inv: false },
  { key: 'E',                  rotulo: 'Equidade territorial',   inv: false },
  { key: 'taxa_retencao',      rotulo: 'Retenção/conclusão',     inv: false },
  { key: 'HHI_mantenedora',    rotulo: 'Desconcentração',        inv: true  },
];
let pesos = DIM.map(() => 1);

// Faixa mín-máx por dimensão
const FAIXA = {};
DIM.forEach(d => {
  const v = UFS.map(u => DADOS[u]?.[d.key]).filter(x => x != null && !isNaN(x));
  FAIXA[d.key] = { min: Math.min(...v), max: Math.max(...v) };
});
function normComp(d, val) {
  if (val == null || isNaN(val)) return null;
  const { min, max } = FAIXA[d.key];
  if (max === min) return 0.5;
  let n = (val - min) / (max - min);
  return d.inv ? 1 - n : n;
}

function indiceDe(uf) {
  let soma = 0, peso = 0, comp = {};
  DIM.forEach((d, i) => {
    const n = normComp(d, DADOS[uf]?.[d.key]);
    comp[d.key] = n;
    if (n != null && pesos[i] > 0) { soma += n * pesos[i]; peso += pesos[i]; }
  });
  return { valor: peso > 0 ? (soma / peso) * 100 : null, comp };
}

function renderSliders() {
  document.getElementById('sliders').innerHTML = DIM.map((d, i) =>
    `<div style="display:flex;align-items:center;gap:10px;margin-bottom:4px;font-size:0.82rem">
       <span style="width:190px">${d.rotulo}</span>
       <input type="range" min="0" max="5" step="1" value="${pesos[i]}" style="flex:1;max-width:280px"
         oninput="pesos[${i}]=+this.value;document.getElementById('pw${i}').textContent=this.value;renderRank()">
       <span id="pw${i}" style="width:18px;text-align:center;font-weight:700;color:var(--blue)">${pesos[i]}</span>
     </div>`).join('');
}
function presetPesos(p) {
  if (p === 'iguais') pesos = DIM.map(() => 1);
  else if (p === 'qualidade') pesos = DIM.map(d => ['IDD', 'pct_doc_doutores', 'cpc_infraestrutura'].includes(d.key) ? 3 : 1);
  else if (p === 'acesso') pesos = DIM.map(d => ['E', 'taxa_retencao', 'HHI_mantenedora'].includes(d.key) ? 3 : 1);
  renderSliders(); renderRank();
}

function corIdx(v) {
  if (v == null) return '#eee';
  const idx = Math.min(8, Math.floor((1 - v / 100) * 9));
  return ['#2166AC', '#4393C3', '#92C5DE', '#D1E5F0', '#F7F7F7', '#FDDBC7', '#F4A582', '#D6604D', '#B2182B'][idx];
}

function renderRank() {
  const linhas = UFS.map(uf => ({ uf, ...indiceDe(uf) }))
    .filter(r => r.valor != null).sort((a, b) => b.valor - a.valor);
  let html = `<thead><tr><th>#</th><th>UF</th><th>IQFF</th>`
    + DIM.map(d => `<th title="${d.rotulo}" style="font-size:0.7rem">${d.rotulo.split(' ')[0]}</th>`).join('')
    + `</tr></thead><tbody>`;
  linhas.forEach((r, i) => {
    html += `<tr><td style="color:var(--text-muted)">${i + 1}º</td>`
      + `<td><a href="uf/${r.uf}.html" title="${NOMES[r.uf] || r.uf}"><span class="uf-tag">${r.uf}</span></a></td>`
      + `<td style="font-weight:700;background:${corIdx(r.valor)}">${r.valor.toFixed(1)}</td>`
      + DIM.map(d => { const n = r.comp[d.key]; return `<td style="font-size:0.78rem;color:var(--text-muted)">${n == null ? '–' : (n * 100).toFixed(0)}</td>`; }).join('')
      + `</tr>`;
  });
  document.getElementById('rank-tbl').innerHTML = html + '</tbody>';
}

document.addEventListener('DOMContentLoaded', () => { renderSliders(); renderRank(); });
</script>
{% endblock %}
