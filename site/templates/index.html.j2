{% extends "base.html.j2" %}

{% block title %}Início — Observatório Nacional da Formação Farmacêutica{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "Observatório Nacional da Formação Farmacêutica — indicadores por UF",
  "description": "Base de indicadores de acesso territorial (ICT, equidade), qualidade (ENADE, IDD, CPC), capacidade (vagas presenciais e EaD, densidade por habitante) e cobertura assistencial (Farmácia Popular) dos cursos de Farmácia nos 27 estados brasileiros, a partir de microdados oficiais.",
  "url": "{{ meta.site_url }}/",
  "inLanguage": "pt-BR",
  "isAccessibleForFree": true,
  "license": "{{ meta.site_url }}/aviso-legal.html",
  "creativeWorkStatus": "Published",
  "datePublished": "{{ meta.data_extracao }}",
  "temporalCoverage": "{{ meta.versao_censo }}",
  "spatialCoverage": { "@type": "Place", "name": "Brasil" },
  "keywords": ["Farmácia", "educação superior", "INEP", "ENADE", "Censo da Educação Superior", "Farmácia Popular", "desertos farmacêuticos", "EaD"],
  "creator": { "@id": "{{ meta.site_url }}/#autor" },
  "publisher": { "@id": "{{ meta.site_url }}/#autor" },
  "isBasedOn": ["INEP/MEC — Censo da Educação Superior e ENADE", "IBGE — estimativas populacionais", "Ministério da Saúde — Farmácia Popular"],
  "distribution": [
    { "@type": "DataDownload", "encodingFormat": "application/json", "contentUrl": "{{ meta.site_url }}/registro_autoral.json" }
  ]
}
</script>
{% endblock %}

{% block content %}

<!-- Herói editorial -->
<section class="hero">
  <p class="hero-eyebrow">Observatório de dados · {{ n_ufs }} estados · Censo INEP {{ meta.versao_censo }}</p>
  <h1 class="hero-title">Quem forma os farmacêuticos do Brasil — e com que qualidade?</h1>
  <p class="hero-lead">
    Um retrato baseado em dados oficiais da oferta de cursos de Farmácia: acesso ao território,
    qualidade da formação, equidade e a acelerada expansão do ensino a distância.
  </p>
  <div class="hero-stats">
    <div class="lede"><span class="lede-num">{{ "{:,}".format(total_vagas_real).replace(',','.') }}</span><span class="lede-lab">vagas por ano</span></div>
    <div class="lede"><span class="lede-num">{{ pct_ead_nacional }}%</span><span class="lede-lab">são a distância</span></div>
    <div class="lede"><span class="lede-num">{{ "{:,}".format(mun_com_oferta).replace(',','.') }}</span><span class="lede-lab">municípios com oferta</span></div>
    <div class="lede"><span class="lede-num accent-neg">{{ "{:,}".format(mun_deserto).replace(',','.') }}</span><span class="lede-lab">desertos farmacêuticos</span></div>
  </div>
  <div class="hero-cta">
    <a class="btn" href="#panorama">Explorar indicadores</a>
    <a class="btn outline" href="correlacoes.html">Ver correlações</a>
    <a class="btn outline" href="indice.html">Índice & ranking</a>
  </div>
</section>

<!-- Barra de atualização -->
<div class="update-bar" aria-live="polite">
  <span class="dot"></span>
  Última extração de dados: {{ meta.data_extracao }} &nbsp;·&nbsp;
  Censo {{ meta.versao_censo }} / ENADE {{ meta.versao_censo }} / Farmácia Popular
  <span style="flex:1"></span>
  <button class="btn outline" onclick="exportarCSV(DADOS_UFS, 'observatorio_nacional.csv')" style="font-size:0.78rem;padding:5px 10px">
    ↓ CSV
  </button>
  <button class="btn outline" onclick="exportarJSON(DADOS_UFS, 'observatorio_nacional.json')" style="font-size:0.78rem;padding:5px 10px;margin-left:6px">
    ↓ JSON
  </button>
</div>

<!-- KPIs nacionais -->
<h2 class="section-title" id="panorama">Panorama Nacional — {{ n_ufs }} UFs</h2>
<div class="kpi-grid">
  <div class="kpi-card">
    <div class="kpi-valor">{{ "{:,}".format(total_vagas_real).replace(',','.') }}</div>
    <div class="kpi-label">Vagas totais (pres + EaD)</div>
    <div class="kpi-fonte" title="Presencial {{ "{:,}".format(total_vagas_pres).replace(',','.') }} + EaD {{ "{:,}".format(total_vagas_ead).replace(',','.') }} ({{ pct_ead_nacional }}% EaD). Fonte: INEP/Censo {{ meta.versao_censo }}.">{{ pct_ead_nacional }}% EaD · Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ n_ies }}</div>
    <div class="kpi-label">IES com Farmácia</div>
    <div class="kpi-fonte" title="Fonte: INEP/Censo {{ meta.versao_censo }}">INEP Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ mun_com_oferta }}</div>
    <div class="kpi-label">Municípios com oferta</div>
    <div class="kpi-fonte" title="Fonte: INEP/Censo {{ meta.versao_censo }}">INEP Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card critico">
    <div class="kpi-valor">{{ mun_deserto }}</div>
    <div class="kpi-label">Desertos farmacêuticos</div>
    <div class="kpi-fonte" title="Municípios sem nenhuma IES com curso de Farmácia em operação">INEP Censo {{ meta.versao_censo }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ "%.3f"|format(ict_mediana) }}</div>
    <div class="kpi-label">ICT mediana nacional</div>
    <div class="kpi-fonte" title="Índice de Concentração Territorial (↓ melhor)">Calculado</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-valor">{{ "%.1f"|format(iaf_mediana) }}</div>
    <div class="kpi-label">IAF mediana nacional</div>
    <div class="kpi-fonte" title="Índice de Adequação Formativa (↑ melhor, 0–100)">ENADE + Censo</div>
  </div>
  {% if vagas_100k_nac is not none %}
  <div class="kpi-card">
    <div class="kpi-valor">{{ "%.1f"|format(vagas_100k_nac) }}</div>
    <div class="kpi-label">Vagas / 100 mil hab.</div>
    <div class="kpi-fonte" title="Vagas totais (pres + EaD) por 100 mil habitantes. População: estimativa IBGE.">Censo + IBGE</div>
  </div>
  {% endif %}
</div>

<!-- Evolução histórica 2015–2024 -->
<h2 class="section-title">Evolução da formação (2015–2024)</h2>
<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px;max-width:82ch">
  Série dos microdados do Censo INEP. As barras mostram as vagas anuais (presencial + EaD);
  a linha mostra os concluintes. Revela a <strong>explosão da EaD</strong> e o descolamento entre
  capacidade ofertada e formandos efetivos.
</p>
<div class="chart-box">
  <canvas id="grafico-historico"></canvas>
</div>
<div class="kpi-grid" id="hist-kpis" style="margin-bottom:28px"></div>

<!-- Seletor de indicador + Mapa -->
<h2 class="section-title">Mapa Nacional por Indicador</h2>
<div class="toolbar">
  <label for="sel-indicador">Colorir por:</label>
  <select id="sel-indicador" onchange="atualizarCorMapa(this.value)">
    <optgroup label="Território &amp; equidade">
      <option value="ICT" selected>ICT — Concentração Territorial (↓ melhor)</option>
      <option value="E">E — Equidade Territorial (↑ melhor)</option>
      <option value="ICON">ICON — Cobertura Assistencial (↑ melhor)</option>
      <option value="ICON_adj">ICON-deserto — FP em desertos (↑ melhor)</option>
    </optgroup>
    <optgroup label="Qualidade (ENADE/CPC 2023)">
      <option value="IAF">IAF — Adequação Formativa (↑ melhor)</option>
      <option value="IDD">IDD — Valor agregado pelo curso (↑ melhor)</option>
      <option value="CPC_cont">CPC — Conceito Preliminar (↑ melhor)</option>
      <option value="pct_doc_doutores">Corpo docente — % doutores (↑ melhor)</option>
      <option value="pct_doc_mestres">Corpo docente — % mestres ou mais (↑ melhor)</option>
      <option value="pct_doc_regime">Corpo docente — % regime integral/parcial (↑ melhor)</option>
      <option value="cpc_org_didatico">Organização didático-pedagógica 1–6 (↑ melhor)</option>
      <option value="cpc_infraestrutura">Infraestrutura física 1–6 (↑ melhor)</option>
      <option value="cpc_oportunidade">Oportunidade de ampliação 1–6 (↑ melhor)</option>
    </optgroup>
    <optgroup label="Mercado">
      <option value="HHI">HHI por IES (↓ melhor)</option>
      <option value="HHI_mantenedora">HHI por mantenedora (↓ melhor)</option>
    </optgroup>
    <optgroup label="Capacidade (magnitude)">
      <option value="vagas_total_real">Vagas totais (pres + EaD)</option>
      <option value="vagas_por_100k">Vagas / 100 mil hab.</option>
      <option value="pct_ead">% EaD da capacidade (↓ melhor)</option>
      <option value="taxa_retencao">Taxa de conclusão (↑ melhor)</option>
      <option value="ead_polos_municipios">Municípios c/ polo EaD</option>
    </optgroup>
    <optgroup label="Acesso &amp; equidade">
      <option value="pct_mulheres">% Mulheres (ingressantes)</option>
      <option value="pct_ppi">% Pretos, pardos e indígenas</option>
      <option value="pct_financiamento">% com FIES ou PROUNI</option>
      <option value="pct_noturno">% Vagas noturnas</option>
      <option value="pct_rede_publica">% Vagas em rede pública</option>
    </optgroup>
  </select>
  <div style="flex:1"></div>
  <div id="mapa-legenda-nacional" class="mapa-legenda" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap"></div>
</div>

<div id="mapa-nacional" aria-label="Mapa coroplético das 27 UFs"></div>

<!-- Tabela comparativa -->
<h2 class="section-title">Comparação entre UFs</h2>
<div class="tabela-wrap">
  <table>
    <thead>
      <tr>
        <th>UF</th>
        <th title="Vagas totais em operação (Censo {{ meta.versao_censo }})">Vagas</th>
        <th title="Índice de Concentração Territorial (↓ melhor)">ICT ↓</th>
        <th title="Índice de Adequação Formativa (↑ melhor, 0–100)">IAF ↑</th>
        <th title="Índice de Cobertura Assistencial (Farmácia Popular / municípios com oferta)">ICON</th>
        <th title="Municípios com pelo menos uma IES com Farmácia">Mun. c/ oferta</th>
        <th title="Municípios sem nenhuma IES com Farmácia">Desertos</th>
        <th title="Índice Herfindahl-Hirschman de concentração por IES">HHI</th>
      </tr>
    </thead>
    <tbody id="tbody-ufs">
      {% for sigla, d in ufs_ordenados %}
      <tr onclick="window.location='uf/{{ sigla }}.html'" style="cursor:pointer">
        <td><a href="uf/{{ sigla }}.html"><span class="uf-tag">{{ sigla }}</span></a></td>
        <td>{{ "{:,}".format(d.vagas_total or 0).replace(',','.') }}</td>
        <td class="{{ 'val-bom' if d.ICT is not none and d.ICT < 0.5 else ('val-medio' if d.ICT is not none and d.ICT < 0.75 else 'val-ruim') }}">
          {% if d.ICT is not none %}{{ "%.3f"|format(d.ICT) }}{% else %}<span class="nodata-cell">sem dados</span>{% endif %}
        </td>
        <td class="{{ 'val-bom' if d.IAF is not none and d.IAF >= 40 else ('val-medio' if d.IAF is not none and d.IAF >= 25 else 'val-ruim') }}">
          {% if d.IAF is not none %}{{ "%.1f"|format(d.IAF) }}{% else %}<span class="nodata-cell">sem dados</span>{% endif %}
        </td>
        <td>{% if d.ICON is not none %}{{ "%.1f"|format(d.ICON) }}{% else %}<span class="nodata-cell">sem dados</span>{% endif %}</td>
        <td>{{ d.municipios_oferta or '–' }}</td>
        <td>{{ d.municipios_deserto or '–' }}</td>
        <td>{% if d.HHI is not none %}{{ "%.4f"|format(d.HHI) }}{% else %}–{% endif %}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% if contexto_regioes %}
<!-- Contexto de mercado por região (oferta × demanda) -->
<h2 class="section-title">Contexto: formação × mercado (por região)</h2>
<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:6px;max-width:82ch">
  Confronto entre a <strong>oferta de formação</strong> (vagas) e o <strong>mercado</strong> (farmácias e drogarias).
  ⚠️ Os dados de mercado só existem de forma aberta por <strong>região</strong> — não por UF; por isso esta leitura é regional,
  sem estimar valores estaduais.
</p>
<div class="tabela-wrap">
  <table>
    <thead>
      <tr>
        <th>Região</th>
        <th title="População residente (IBGE)">População</th>
        <th title="Vagas de Farmácia/ano (pres + EaD)">Vagas/ano</th>
        <th title="Vagas por 100 mil habitantes">Vagas/100k</th>
        <th title="Farmácias e drogarias em atividade (2024)">Farmácias</th>
        <th title="Farmácias por 100 mil habitantes">Farm./100k</th>
        <th title="Novas vagas de formação por farmácia existente — proxy de pressão de oferta">Vagas/farmácia</th>
      </tr>
    </thead>
    <tbody>
      {% for r in contexto_regioes %}
      <tr>
        <td><strong>{{ r.regiao }}</strong></td>
        <td>{{ "{:,}".format(r.populacao).replace(',','.') }}</td>
        <td>{{ "{:,}".format(r.vagas).replace(',','.') }}</td>
        <td>{{ "%.1f"|format(r.vagas_100k) if r.vagas_100k is not none else '–' }}</td>
        <td>{{ "{:,}".format(r.farmacias).replace(',','.') if r.farmacias else '–' }}</td>
        <td>{{ "%.1f"|format(r.farmacias_100k) if r.farmacias_100k is not none else '–' }}</td>
        <td>{{ "%.2f"|format(r.vagas_por_farmacia) if r.vagas_por_farmacia is not none else '–' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
<p style="font-size:0.78rem;color:var(--text-muted);margin-top:8px;max-width:82ch">
  Brasil {{ contexto_meta.ano }}: <strong>{{ "{:,}".format(contexto_meta.total_farmaceuticos).replace(',','.') }}</strong> farmacêuticos e
  <strong>{{ "{:,}".format(contexto_meta.total_farmacias).replace(',','.') }}</strong> farmácias/drogarias.
  Fontes: {{ contexto_meta.fonte_farm }}; {{ contexto_meta.fonte_prof }}. População: IBGE.
  <br>Leitura: "vagas por farmácia" aproxima a <em>pressão de formação</em> — quantas vagas novas de Farmácia são abertas por ano
  para cada farmácia em operação; valores altos sugerem formação crescendo acima da base de mercado regional.
</p>
{% endif %}

{% endblock %}

{% block scripts %}
<script>
const DADOS_UFS = {{ dados_ufs_json }};
const META = {{ meta_json }};
const SERIE = {{ serie_historica_json }};

function renderHistorico() {
  if (!SERIE || !SERIE.nacional || !SERIE.nacional.length) return;
  const s = SERIE.nacional;
  const anos = s.map(r => r.ano);
  const nf = n => Number(n || 0).toLocaleString('pt-BR');
  const ctx = document.getElementById('grafico-historico').getContext('2d');
  new Chart(ctx, {
    data: {
      labels: anos,
      datasets: [
        { type: 'bar', label: 'Vagas presenciais', data: s.map(r => r.vagas_presencial),
          backgroundColor: '#2E5496', stack: 'vagas', yAxisID: 'y' },
        { type: 'bar', label: 'Vagas EaD', data: s.map(r => r.vagas_ead),
          backgroundColor: '#B07D22', stack: 'vagas', yAxisID: 'y' },
        { type: 'line', label: 'Concluintes', data: s.map(r => r.concluintes),
          borderColor: '#B23A2E', backgroundColor: '#B23A2E', borderWidth: 2.5,
          pointRadius: 3, yAxisID: 'y2', tension: 0.25 },
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { position: 'bottom', labels: { font: { size: 11 } } },
        tooltip: { callbacks: { footer: items => {
          const r = s[items[0].dataIndex];
          return `EaD: ${r.pct_ead}% das vagas`;
        } } }
      },
      scales: {
        y:  { stacked: true, position: 'left', title: { display: true, text: 'Vagas/ano', font: { size: 10 } } },
        y2: { position: 'right', grid: { drawOnChartArea: false }, title: { display: true, text: 'Concluintes', font: { size: 10 } } },
        x:  { stacked: true }
      }
    }
  });
  // KPIs de variação 2015→2024
  const a = s[0], b = s[s.length - 1];
  const card = (val, lab, fonte) => `<div class="kpi-card"><div class="kpi-valor">${val}</div><div class="kpi-label">${lab}</div><div class="kpi-fonte">${fonte}</div></div>`;
  const mult = (x, y) => (y / x).toFixed(1) + '×';
  document.getElementById('hist-kpis').innerHTML =
    card(mult(a.vagas_total, b.vagas_total), 'Crescimento das vagas', `${nf(a.vagas_total)} → ${nf(b.vagas_total)} (2015→2024)`) +
    card((b.pct_ead - a.pct_ead).toFixed(0) + ' p.p.', 'Avanço da EaD', `${a.pct_ead}% → ${b.pct_ead}% das vagas`) +
    card(mult(a.concluintes, b.concluintes), 'Crescimento dos concluintes', `${nf(a.concluintes)} → ${nf(b.concluintes)}`) +
    card(mult(a.matriculas, b.matriculas), 'Crescimento das matrículas', `${nf(a.matriculas)} → ${nf(b.matriculas)}`);
}

document.addEventListener('DOMContentLoaded', () => {
  iniciarMapaNacional(DADOS_UFS);
  renderHistorico();
});
</script>
{% endblock %}
