    <symbol id="i-source" viewBox="0 0 24 24"><path d="M3 9l9-5 9 5M5 9v9M19 9v9M9 9v9M15 9v9M3 19h18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></symbol>
