<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="google-site-verification" content="jux-9JIdwL1MqpC8UyBoblmg9u5ZC5QhqiZjYjCQGEE" />
  <title>{% block title %}Observatório Nacional da Formação Farmacêutica{% endblock %}</title>
  <meta name="description" content="{% block meta_description %}Indicadores de acesso territorial, qualidade e cobertura assistencial da formação farmacêutica no Brasil — 27 estados, dados oficiais INEP, IBGE e Ministério da Saúde.{% endblock %}">

  <!-- Segurança: política de conteúdo e privacidade do referenciador -->
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.basemaps.cartocdn.com https://*.cartocdn.com https://servicodados.ibge.gov.br; connect-src 'self' https://servicodados.ibge.gov.br; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; upgrade-insecure-requests">
  <meta name="referrer" content="strict-origin-when-cross-origin">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#16304F">

  <!-- SEO / compartilhamento -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Observatório Nacional da Formação Farmacêutica">
  <meta property="og:title" content="{% block og_title %}Observatório Nacional da Formação Farmacêutica{% endblock %}">
  <meta property="og:description" content="Indicadores de acesso, qualidade e cobertura da formação farmacêutica nos 27 estados do Brasil.">
  <meta property="og:locale" content="pt_BR">
  <meta name="author" content="Edson Sidião de Souza Júnior">
  <link rel="stylesheet" href="{{ depth }}static/css/style.css">

  <!-- Dados estruturados (schema.org) — site e autor -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "{{ meta.site_url }}/#website",
        "url": "{{ meta.site_url }}/",
        "name": "Observatório Nacional da Formação Farmacêutica",
        "description": "Indicadores de acesso territorial, qualidade e cobertura assistencial da formação farmacêutica nos 27 estados do Brasil.",
        "inLanguage": "pt-BR",
        "publisher": { "@id": "{{ meta.site_url }}/#autor" }
      },
      {
        "@type": "Person",
        "@id": "{{ meta.site_url }}/#autor",
        "name": "Edson Sidião de Souza Júnior",
        "jobTitle": "Farmacêutico · Avaliador ad hoc INEP/MEC · Consultor em Gestão Educacional",
        "identifier": "CRF/GO 3686",
        "url": "{{ meta.site_url }}/autor.html",
        "email": "mailto:sidiao@i9educar.com",
        "telephone": "+55-62-99804-4822",
        "alumniOf": { "@type": "CollegeOrUniversity", "name": "Universidade Federal de Goiás" },
        "knowsAbout": ["Farmácia", "Educação Superior", "Medicina Tropical", "Avaliação MEC/INEP", "Parasitologia"],
        "sameAs": ["http://lattes.cnpq.br/9464330669014306"]
      }
    ]
  }
  </script>
  {% block structured_data %}{% endblock %}
  <!-- Leaflet (hospedado localmente — sem dependência de CDN externo) -->
  <link rel="stylesheet" href="{{ depth }}static/vendor/leaflet/leaflet.css">
  <script src="{{ depth }}static/vendor/leaflet/leaflet.js"></script>
  <!-- Chart.js (local) -->
  <script src="{{ depth }}static/vendor/chart.umd.min.js"></script>
  {% block head_extra %}{% endblock %}
</head>
<body>

<header class="site-header" role="banner">
  <div>
    <h1>Observatório Nacional da Formação Farmacêutica</h1>
    <p>Indicadores de acesso territorial, qualidade e cobertura assistencial · Censo INEP {{ meta.versao_censo }}</p>
  </div>
</header>

<nav class="navbar" aria-label="Navegação">
  {% block breadcrumb %}
  <a href="{{ depth }}index.html">Início</a>
  {% endblock %}
  <span class="sep">·</span>
  <a href="{{ depth }}comparar.html" style="color:var(--text-muted);font-size:0.82rem">Comparar UFs</a>
  <span class="sep">·</span>
  <a href="{{ depth }}correlacoes.html" style="color:var(--text-muted);font-size:0.82rem">Correlações</a>
  <span class="sep">·</span>
  <a href="{{ depth }}indice.html" style="color:var(--text-muted);font-size:0.82rem">Índice & Ranking</a>
  <span class="sep">·</span>
  <a href="{{ depth }}autor.html" style="color:var(--text-muted);font-size:0.82rem">Sobre o Autor</a>
  <span class="sep">·</span>
  <a href="#glossario" class="nav-glossario" style="font-size:0.82rem">📖 Entenda os indicadores</a>
  <span class="sep">·</span>
  <a href="{{ depth }}aviso-legal.html" style="color:var(--text-muted);font-size:0.82rem">© Direitos Autorais</a>
  <div style="flex:1"></div>
  <span style="font-size:0.78rem;color:var(--text-muted)">
    Dados: {{ meta.data_extracao | default('2025-01-01') }}
  </span>
</nav>
<script>
/* Remove do menu o link da página atual (já mostrada no breadcrumb), evitando duplicidade. */
(function () {
  var atual = (location.pathname.split('/').pop() || 'index.html');
  document.querySelectorAll('.navbar a').forEach(function (a) {
    var href = a.getAttribute('href') || '';
    if (href.charAt(0) === '#') return;
    var alvo = href.split('/').pop().split('#')[0].split('?')[0];
    if (alvo === atual) {
      var sep = a.previousElementSibling;
      if (sep && sep.classList && sep.classList.contains('sep')) sep.remove();
      a.remove();
    }
  });
})();
</script>

<main>
  {% block content %}{% endblock %}

  <!-- Glossário interativo (renderizado por app.js a partir de GLOSSARIO) -->
  <section id="glossario" class="glossario" aria-label="Glossário de indicadores">
    <h2 class="section-title">📖 Entenda os indicadores</h2>
    <p class="glossario-intro">
      Cada indicador abaixo explica <strong>o que mede</strong>, sua <strong>escala</strong>,
      se <strong>maior ou menor é melhor</strong> e a <strong>fonte oficial</strong>.
      Clique em qualquer cartão de KPI nas seções acima para saltar direto à sua explicação.
    </p>
    <div class="glossario-busca">
      <input type="search" id="glossario-filtro" placeholder="🔎 Buscar indicador (ex.: ICT, EaD, desertos, qualidade…)"
             oninput="filtrarGlossario(this.value)" aria-label="Buscar indicador">
    </div>
    <div id="glossario-lista" class="glossario-lista"></div>
  </section>
</main>

<footer class="site-footer">
  <p>Observatório Nacional da Formação Farmacêutica · Dados: INEP/Censo {{ meta.versao_censo }}, ENADE/CPC 2023, IBGE, Farmácia Popular</p>
  <p style="margin-top:6px">
    © {{ (meta.data_extracao or '2026')[:4] }} <strong>Edson Sidião de Souza Júnior</strong> · Todos os direitos reservados ·
    Obra protegida pelas Leis nº 9.610/1998 e nº 9.609/1998 ·
    <a href="{{ depth }}aviso-legal.html" style="color:#cdd8ea;text-decoration:underline">Direitos Autorais e Condições de Uso</a>
  </p>
  <p style="margin-top:6px;opacity:0.8">Dados primários de fontes oficiais públicas; o tratamento, os indicadores e a análise são obra autoral original.</p>
</footer>

<script>window._GEO_BASE = '{{ depth }}';</script>
<script src="{{ depth }}static/js/app.js"></script>
<script src="{{ depth }}static/js/glossario.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>
