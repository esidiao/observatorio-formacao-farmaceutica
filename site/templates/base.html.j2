<header class="site-header" role="banner">
  <a href="{{ depth }}index.html" class="brand" aria-label="Página inicial">
    <img src="{{ depth }}static/img/logo.png" alt="" class="brand-mark" width="48" height="48">
    <span class="brand-text">
      <span class="brand-name">Observatório Nacional</span>
      <span class="brand-sub">da Formação Farmacêutica</span>
    </span>
  </a>
  <p class="header-tag">Indicadores de acesso territorial, qualidade e cobertura assistencial · Censo INEP {{ meta.versao_censo }}</p>
</header>

<nav class="navbar" aria-label="Navegação">
  <a href="{{ depth }}index.html" class="nav-home" title="Página inicial" aria-label="Início"><svg class="ic"><use href="#i-home"/></svg></a>
  <span class="breadcrumb-trail">
    {% block breadcrumb %}{% endblock %}
  </span>
  <span class="nav-menu">
    <a href="{{ depth }}comparar.html" style="color:var(--text-muted);font-size:0.82rem">Comparar UFs</a>
    <span class="sep">·</span>
    <a href="{{ depth }}correlacoes.html" style="color:var(--text-muted);font-size:0.82rem">Correlações</a>
    <span class="sep">·</span>
    <a href="{{ depth }}indice.html" style="color:var(--text-muted);font-size:0.82rem">Índice & Ranking</a>
    <span class="sep">·</span>
    <a href="{{ depth }}autor.html" style="color:var(--text-muted);font-size:0.82rem">Sobre o Autor</a>
    <span class="sep">·</span>
    <a href="#glossario" class="nav-glossario" style="font-size:0.82rem"><svg class="ic"><use href="#i-book"/></svg> Entenda os indicadores</a>
    <span class="sep">·</span>
    <a href="{{ depth }}aviso-legal.html" style="color:var(--text-muted);font-size:0.82rem">© Direitos Autorais</a>
  </span>
  <div style="flex:1"></div>
  <span style="font-size:0.78rem;color:var(--text-muted)">
    Dados: {{ meta.data_extracao | default('2025-01-01') }}
  </span>
</nav>
<script>
/* Destaca no menu o link da página atual e remove a duplicata; nunca mexe no
   ícone de início (nav-home) nem no breadcrumb. */
(function () {
  var atual = (location.pathname.split('/').pop() || 'index.html');
  document.querySelectorAll('.nav-menu a').forEach(function (a) {
    var href = a.getAttribute('href') || '';
    if (href.charAt(0) === '#') return;
    var alvo = href.split('/').pop().split('#')[0].split('?')[0];
    if (alvo === atual) {
      var sepPrev = a.previousElementSibling;
      if (sepPrev && sepPrev.classList && sepPrev.classList.contains('sep')) {
        sepPrev.remove();
      } else {
        var sepNext = a.nextElementSibling;
        if (sepNext && sepNext.classList && sepNext.classList.contains('sep')) sepNext.remove();
      }
      a.remove();
    }
  });
})();
</script>

<main>
  {% block content %}{% endblock %}

  <!-- Glossário interativo (renderizado por app.js a partir de GLOSSARIO) -->
  <section id="glossario" class="glossario" aria-label="Glossário de indicadores">
    <h2 class="section-title"><svg class="ic" style="color:var(--accent)"><use href="#i-book"/></svg> Entenda os indicadores</h2>
    <p class="glossario-intro">
      Cada indicador abaixo explica <strong>o que mede</strong>, sua <strong>escala</strong>,
      se <strong>maior ou menor é melhor</strong> e a <strong>fonte oficial</strong>.
      Clique em qualquer cartão de KPI nas seções acima para saltar direto à sua explicação.
    </p>
    <div class="glossario-busca">
      <input type="search" id="glossario-filtro" placeholder="🔎 Buscar indicador (ex.: ICT, EaD, desertos, qualidade…)"
             oninput="filtrarGlossario(this.value)" aria-label="Buscar indicador">
    </div>
    <div id="glossario-lista" class="glossario-lista"></div>
  </section>
</main>

<footer class="site-footer">
  <p>Observatório Nacional da Formação Farmacêutica · Dados: INEP/Censo {{ meta.versao_censo }}, ENADE/CPC 2023, IBGE, Farmácia Popular</p>
  <p style="margin-top:6px">
    © {{ (meta.data_extracao or '2026')[:4] }} <strong>Edson Sidião de Souza Júnior</strong> · Todos os direitos reservados ·
    Obra protegida pelas Leis nº 9.610/1998 e nº 9.609/1998 ·
    <a href="{{ depth }}aviso-legal.html" style="color:#cdd8ea;text-decoration:underline">Direitos Autorais e Condições de Uso</a>
  </p>
  <p style="margin-top:6px;opacity:0.8">Dados primários de fontes oficiais públicas; o tratamento, os indicadores e a análise são obra autoral original.</p>
  <p id="contador-visitas" class="contador-visitas" hidden>
    <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" style="vertical-align:-2px">
      <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12Z" fill="none" stroke="currentColor" stroke-width="1.6"/>
      <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="1.6"/>
    </svg>
    <span id="contador-num">—</span> visitas
  </p>
</footer>

<script>window._GEO_BASE = '{{ depth }}';</script>
<script src="{{ depth }}static/js/app.js"></script>
<script src="{{ depth }}static/js/glossario.js"></script>
{% block scripts %}{% endblock %}
<script>
if ('serviceWorker' in navigator) {
  window.addEventListener('load', function () {
    navigator.serviceWorker.register('{{ depth }}sw.js', {scope: '/observatorio-formacao-farmaceutica/'})
      .catch(function (e) { console.warn('SW registro falhou:', e); });
  });
}
/* Contador de visitas — serviço externo gratuito, sem cadastro nem cookies.
   Incrementa uma vez por sessão do navegador; nas demais páginas apenas lê.
   Falha em silêncio (o elemento fica oculto) se o serviço estiver indisponível. */
(function () {
  var API = 'https://abacus.jasoncameron.dev';
  var NS = 'obs-farmaceutica-esidiao', KEY = 'site';
  var jaContou = false;
  try { jaContou = sessionStorage.getItem('onff_visita') === '1'; } catch (e) {}
  var url = API + (jaContou ? '/get/' : '/hit/') + NS + '/' + KEY;
  fetch(url, { cache: 'no-store' })
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (d) {
      if (!d || typeof d.value !== 'number') return;
      try { sessionStorage.setItem('onff_visita', '1'); } catch (e) {}
      var el = document.getElementById('contador-num');
      var box = document.getElementById('contador-visitas');
      if (el && box) { el.textContent = d.value.toLocaleString('pt-BR'); box.hidden = false; }
    })
    .catch(function () { /* silêncio: mantém oculto */ });
})();
</script>
</body>
</html>
